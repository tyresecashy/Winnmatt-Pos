# Notifications (optional — logs to DB only without these keys)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=WinnMatt POS <notifications@winnmatt.com>
# AFRICASTALKING_API_KEY=atsk_xxxxxxxxxxxx
# AFRICASTALKING_USERNAME=sandbox
# SMS_FROM=WINNMATT

# Application Configuration
