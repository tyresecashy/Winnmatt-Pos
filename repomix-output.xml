import { NextRequest, NextResponse } from 'next/server'
import { supabaseAdmin } from '@/lib/supabase-server'

/**
 * GET /api/auth/profile
 * 
 * Fetches the user profile from the custom users table.
 * Requires X-User-ID header with the Supabase auth user ID.
 * 
 * Returns 200 with profile on success
 * Returns 404 if profile not found
 * Returns 401 if no user ID provided
 */
export async function GET(request: NextRequest) {
  try {
    const userId = request.headers.get('X-User-ID')
    
    if (!userId) {
      console.warn('[PROFILE] Missing X-User-ID header')
      return NextResponse.json(
        { error: 'Missing X-User-ID header' },
        { status: 401 }
      )
    }

    console.log('[PROFILE] Fetching profile for userId:', userId)

    // First attempt: try with branch relation
    const { data, error } = await supabaseAdmin
      .from('users')
      .select(`
        id,
        email,
        full_name,
        role,
        branch_id,
        created_at,
        updated_at,
        branch:branches(id, name, code)
      `)
      .eq('id', userId)
      .single()

    if (error) {
      console.error('[PROFILE] Query error:', {
        code: error.code,
        message: error.message,
        details: error.details,
      })

      if (error.code === 'PGRST116') {
        // No rows returned
        console.warn('[PROFILE] PGRST116: User not found in database')
        return NextResponse.json(
          { error: 'User profile not found' },
          { status: 404 }
        )
      }

      // If it's a relation error, try without relation
      if (error.message?.includes('relation') || error.message?.includes('branch')) {
        console.log('[PROFILE] Relation error detected, retrying without branch relation')
        
        const { data: dataNoRel, error: errorNoRel } = await supabaseAdmin
          .from('users')
          .select(`
            id,
            email,
            full_name,
            role,
            branch_id,
            created_at,
            updated_at
          `)
          .eq('id', userId)
          .single()

        if (errorNoRel) {
          console.error('[PROFILE] Retry failed:', errorNoRel.message)
          throw errorNoRel
        }

        // Fetch branch separately
        console.log('[PROFILE] Fetching branch separately, branch_id:', dataNoRel.branch_id)
        const { data: branchData, error: branchError } = await supabaseAdmin
          .from('branches')
          .select('id, name, code')
          .eq('id', dataNoRel.branch_id)
          .single()

        if (branchError) {
          console.error('[PROFILE] Branch fetch error:', branchError.message)
          // Continue without branch info
          return NextResponse.json({ profile: dataNoRel })
        }

        const profileWithBranch = {
          ...dataNoRel,
          branch: branchData,
        }
        console.log('[PROFILE] ✅ Profile loaded successfully (with separate branch fetch):', profileWithBranch.email, profileWithBranch.role)
        return NextResponse.json({ profile: profileWithBranch })
      }

      throw error
    }

    console.log('[PROFILE] ✅ Profile loaded successfully:', data.email, data.role)
    return NextResponse.json({ profile: data })
  } catch (error) {
    console.error('[PROFILE] ❌ Unhandled error:', error instanceof Error ? error.message : String(error))
    return NextResponse.json(
      { error: 'Failed to fetch profile', details: error instanceof Error ? error.message : 'Unknown error' },
      { status: 500 }
    )
  }
}

/**
 * POST /api/auth/profile
 * 
 * DISABLED for user self-service
 * 
 * Profile auto-creation is NOT supported. Accounts must be explicitly provisioned
 * by administrators through a dedicated admin interface (to be implemented).
