// API endpoint: POST /api/prices/review
// Handle price review actions: approve, reject (with correction), protect
// Admin only

import { createClient } from '@/lib/supabase-server'
import {
  approvePriceReview,
  rejectPriceReview,
  protectPrice,
} from '@/lib/price-audit-service'
import { NextResponse } from 'next/server'

export async function POST(request: Request) {
  const supabase = createClient()

  // Check auth and admin role
  const {
    data: { user },
  } = await supabase.auth.getUser()

  if (!user) {
    return NextResponse.json({ error: 'Unauthorized' }, { status: 401 })
  }

  // Check if admin
  const { data: userData } = await supabase
    .from('users')
    .select('role')
    .eq('id', user.id)
    .single()

  if (userData?.role !== 'admin') {
    return NextResponse.json({ error: 'Admin only' }, { status: 403 })
  }

  try {
    const body = await request.json()
    const { action, productId, newSellingPrice, newPurchasePrice, reason, protectionLevel, expiresAt } = body

    if (!action || !productId) {
      return NextResponse.json(
        { error: 'Missing required fields: action, productId' },
        { status: 400 }
      )
    }

    switch (action) {
      case 'approve': {
        await approvePriceReview(productId, user.id, reason)
        return NextResponse.json({
          success: true,
          message: 'Price approved',
          action: 'approve',
        })
      }

      case 'correct': {
        if (newSellingPrice === undefined || newPurchasePrice === undefined) {
          return NextResponse.json(
            { error: 'Missing required fields for correction: newSellingPrice, newPurchasePrice' },
            { status: 400 }
          )
        }

        await rejectPriceReview(
          productId,
          newSellingPrice,
          newPurchasePrice,
          user.id,
          reason || 'Admin corrected prices'
        )

        return NextResponse.json({
          success: true,
          message: 'Price corrected and approved',
          action: 'correct',
          newSellingPrice,
          newPurchasePrice,
        })
      }

      case 'protect': {
        const level = protectionLevel || 'high'
        await protectPrice(
          productId,
          user.id,
          level,
          reason,
          expiresAt ? new Date(expiresAt) : undefined
        )

        return NextResponse.json({
          success: true,
          message: `Price protected at ${level} level`,
          action: 'protect',
        })
      }

      default:
        return NextResponse.json(
          { error: `Unknown action: ${action}. Must be 'approve', 'correct', or 'protect'` },
          { status: 400 }
        )
    }
  } catch (error: any) {
    console.error('Error in price review:', error)
    return NextResponse.json(
      { error: error.message || 'Internal server error' },
      { status: 500 }
    )
  }
}
</file>

