  1. SKU123 (exact match - score 1000, _isExactMatch = true)
  2. SKU1234 (fuzzy match - score 100, _isExactMatch = false)
  3. SKU123-BLACK (fuzzy match - score 100)
  4. Product SKU123 (fuzzy match - score 100)

