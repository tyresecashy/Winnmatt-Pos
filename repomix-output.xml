"use client"

import { useState } from "react"
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card"
import { Button } from "@/components/ui/button"
import { Input } from "@/components/ui/input"
import { Badge } from "@/components/ui/badge"
import { Tabs, TabsContent, TabsList, TabsTrigger } from "@/components/ui/tabs"
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from "@/components/ui/table"
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogHeader,
  DialogTitle,
  DialogTrigger,
} from "@/components/ui/dialog"
import { Plus, Search, Building2, Phone, User, CreditCard, FileText, MapPin } from "lucide-react"
import { businessAccounts, branches, formatKSh } from "@/lib/mock-data"

const pricingLevelColors: Record<string, string> = {
  wholesale: "bg-green-100 text-green-700",
  "wholesale-plus": "bg-blue-100 text-blue-700",
}

export default function BusinessAccountsPage() {
  const [searchTerm, setSearchTerm] = useState("")
  const [selectedAccount, setSelectedAccount] = useState<typeof businessAccounts[0] | null>(null)

  const filteredAccounts = businessAccounts.filter((account) => {
    return (
      account.businessName.toLowerCase().includes(searchTerm.toLowerCase()) ||
      account.contactPerson.toLowerCase().includes(searchTerm.toLowerCase()) ||
      account.phone.includes(searchTerm)
    )
  })

  const totalCreditLimit = businessAccounts.reduce((sum, a) => sum + a.creditLimit, 0)
  const totalBalance = businessAccounts.reduce((sum, a) => sum + a.balance, 0)
  const utilizationRate = (totalBalance / totalCreditLimit) * 100

  return (
    <div className="p-6 space-y-6">
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-bold tracking-tight">Business Accounts</h1>
          <p className="text-muted-foreground">
            Manage wholesale and business customer accounts
          </p>
        </div>
        <Button>
          <Plus className="mr-2 h-4 w-4" />
          Add Business Account
        </Button>
      </div>

      <div className="grid gap-4 md:grid-cols-4">
        <Card>
          <CardHeader className="pb-2">
            <CardDescription>Total Accounts</CardDescription>
            <CardTitle className="text-3xl">{businessAccounts.length}</CardTitle>
          </CardHeader>
        </Card>
        <Card>
          <CardHeader className="pb-2">
            <CardDescription>Total Credit Limit</CardDescription>
            <CardTitle className="text-2xl">{formatKSh(totalCreditLimit)}</CardTitle>
          </CardHeader>
        </Card>
        <Card>
          <CardHeader className="pb-2">
            <CardDescription>Outstanding Balance</CardDescription>
            <CardTitle className="text-2xl text-primary">{formatKSh(totalBalance)}</CardTitle>
          </CardHeader>
        </Card>
        <Card>
          <CardHeader className="pb-2">
            <CardDescription>Credit Utilization</CardDescription>
            <CardTitle className="text-2xl">{utilizationRate.toFixed(1)}%</CardTitle>
          </CardHeader>
        </Card>
      </div>

      <Card>
        <CardHeader>
          <div className="flex items-center gap-4">
            <div className="relative flex-1 max-w-sm">
              <Search className="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-muted-foreground" />
              <Input
                placeholder="Search businesses..."
                value={searchTerm}
                onChange={(e) => setSearchTerm(e.target.value)}
                className="pl-9"
              />
            </div>
          </div>
        </CardHeader>
        <CardContent>
          <Table>
            <TableHeader>
              <TableRow>
                <TableHead>Business Name</TableHead>
                <TableHead>Contact Person</TableHead>
                <TableHead>Phone</TableHead>
                <TableHead>Branch</TableHead>
                <TableHead>Pricing Level</TableHead>
                <TableHead className="text-right">Credit Limit</TableHead>
                <TableHead className="text-right">Balance</TableHead>
                <TableHead></TableHead>
              </TableRow>
            </TableHeader>
            <TableBody>
              {filteredAccounts.map((account) => (
                <TableRow key={account.id}>
                  <TableCell>
                    <div className="flex items-center gap-3">
                      <div className="flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10">
                        <Building2 className="h-5 w-5 text-primary" />
                      </div>
                      <span className="font-medium">{account.businessName}</span>
                    </div>
                  </TableCell>
                  <TableCell>
                    <div className="flex items-center gap-1 text-muted-foreground">
                      <User className="h-3 w-3" />
                      {account.contactPerson}
                    </div>
                  </TableCell>
                  <TableCell>
                    <div className="flex items-center gap-1 text-muted-foreground">
                      <Phone className="h-3 w-3" />
                      {account.phone}
                    </div>
                  </TableCell>
                  <TableCell>
                    <div className="flex items-center gap-1 text-muted-foreground">
                      <MapPin className="h-3 w-3" />
                      {branches.find(b => b.id === account.branch)?.name.split(' ')[0]}
                    </div>
                  </TableCell>
                  <TableCell>
                    <Badge
                      variant="secondary"
                      className={pricingLevelColors[account.pricingLevel]}
                    >
                      {account.pricingLevel}
                    </Badge>
                  </TableCell>
                  <TableCell className="text-right">
                    {formatKSh(account.creditLimit)}
                  </TableCell>
                  <TableCell className="text-right">
                    <span className={account.balance > 0 ? "text-primary font-medium" : "text-green-600"}>
                      {formatKSh(account.balance)}
                    </span>
                  </TableCell>
                  <TableCell>
                    <Dialog>
                      <DialogTrigger asChild>
                        <Button
                          variant="ghost"
                          size="sm"
                          onClick={() => setSelectedAccount(account)}
                        >
                          View
                        </Button>
                      </DialogTrigger>
                      <DialogContent className="sm:max-w-2xl">
                        <DialogHeader>
                          <DialogTitle>Business Account Details</DialogTitle>
                          <DialogDescription>
                            View account information, orders, and payment history
                          </DialogDescription>
                        </DialogHeader>
                        {selectedAccount && (
                          <Tabs defaultValue="details" className="mt-4">
                            <TabsList className="grid w-full grid-cols-3">
                              <TabsTrigger value="details">Details</TabsTrigger>
                              <TabsTrigger value="orders">Orders</TabsTrigger>
                              <TabsTrigger value="payments">Payments</TabsTrigger>
                            </TabsList>

                            <TabsContent value="details" className="space-y-4 pt-4">
                              <div className="flex items-start gap-4">
                                <div className="flex h-16 w-16 items-center justify-center rounded-xl bg-primary/10">
                                  <Building2 className="h-8 w-8 text-primary" />
                                </div>
                                <div className="flex-1">
                                  <h3 className="text-xl font-semibold">{selectedAccount.businessName}</h3>
                                  <p className="text-muted-foreground">{selectedAccount.contactPerson}</p>
                                  <div className="flex items-center gap-4 mt-2">
                                    <Badge
                                      variant="secondary"
                                      className={pricingLevelColors[selectedAccount.pricingLevel]}
                                    >
                                      {selectedAccount.pricingLevel}
                                    </Badge>
                                    <span className="text-sm text-muted-foreground flex items-center gap-1">
                                      <Phone className="h-3 w-3" />
                                      {selectedAccount.phone}
                                    </span>
                                  </div>
                                </div>
                              </div>

                              <div className="grid grid-cols-3 gap-4">
                                <div className="rounded-lg bg-muted/50 p-4">
                                  <CreditCard className="h-5 w-5 text-muted-foreground mb-2" />
                                  <p className="text-lg font-bold">{formatKSh(selectedAccount.creditLimit)}</p>
                                  <p className="text-xs text-muted-foreground">Credit Limit</p>
                                </div>
                                <div className="rounded-lg bg-muted/50 p-4">
                                  <p className="text-lg font-bold text-primary">{formatKSh(selectedAccount.balance)}</p>
                                  <p className="text-xs text-muted-foreground">Outstanding Balance</p>
                                </div>
                                <div className="rounded-lg bg-muted/50 p-4">
                                  <p className="text-lg font-bold">{formatKSh(selectedAccount.creditLimit - selectedAccount.balance)}</p>
                                  <p className="text-xs text-muted-foreground">Available Credit</p>
                                </div>
                              </div>

                              {selectedAccount.notes && (
                                <div className="rounded-lg bg-muted/30 p-4">
                                  <div className="flex items-center gap-2 mb-2">
                                    <FileText className="h-4 w-4 text-muted-foreground" />
                                    <span className="text-sm font-medium">Notes</span>
                                  </div>
                                  <p className="text-sm text-muted-foreground">{selectedAccount.notes}</p>
                                </div>
                              )}
                            </TabsContent>

                            <TabsContent value="orders" className="pt-4">
                              <div className="space-y-3">
                                {[
                                  { date: "Mar 28, 2026", items: 45, total: 125000, status: "delivered" },
