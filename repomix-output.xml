    setBranchFormData(prev => ({
      ...prev,
      [field]: value || null
    }))
  }
  
  // Save branch settings
  const handleSaveBranchSettings = async () => {
    if (!profile || profile.role !== 'admin') {
      setBranchSaveStatus('error')
      setBranchSaveMessage('Only admins can edit branch settings')
      return
