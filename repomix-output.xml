<file path="components/pos/customer-lookup.tsx">
"use client"

import { useState, useCallback } from "react"
import { Input } from "@/components/ui/input"
import { Button } from "@/components/ui/button"
import { Badge } from "@/components/ui/badge"
import { Search, User, X, Phone, Loader2 } from "lucide-react"
import { searchCustomers } from "@/lib/customers-actions"
import { formatKSh, pointsToKSh } from "@/lib/currency"
import type { SelectedCustomer } from "@/app/(dashboard)/pos/page"
import {
  Command,
  CommandEmpty,
  CommandGroup,
  CommandInput,
  CommandItem,
  CommandList,
} from "@/components/ui/command"
import {
  Popover,
  PopoverContent,
  PopoverTrigger,
} from "@/components/ui/popover"

interface CustomerLookupProps {
  selectedCustomer: SelectedCustomer | null
  onSelectCustomer: (customer: SelectedCustomer | null) => void
  loyaltyRedeemValue?: number
}

const customerTypeColors: Record<string, string> = {
  retail: "bg-blue-100 text-blue-700",
  wholesale: "bg-green-100 text-green-700",
  business: "bg-purple-100 text-purple-700",
}

export function CustomerLookup({ selectedCustomer, onSelectCustomer, loyaltyRedeemValue }: CustomerLookupProps) {
  const [open, setOpen] = useState(false)
  const [searchQuery, setSearchQuery] = useState("")
  const [searchResults, setSearchResults] = useState<any[]>([])
  const [isSearching, setIsSearching] = useState(false)

  // Handle real-time search from database
  const handleSearch = useCallback(async (query: string) => {
    setSearchQuery(query)
    
    if (!query.trim()) {
      setSearchResults([])
      return
    }

    setIsSearching(true)
    try {
      const results = await searchCustomers(query)
      setSearchResults(results)
    } catch (error) {
      console.error('Error searching customers:', error)
      setSearchResults([])
    } finally {
      setIsSearching(false)
    }
  }, [])

  if (selectedCustomer) {
    return (
      <div className="px-4 py-3 border-b bg-muted/30">
        <div className="flex items-center gap-3">
          <div className="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-primary/10">
            <User className="h-5 w-5 text-primary" />
          </div>
          <div className="flex-1 min-w-0">
            <div className="flex items-center gap-2">
              <p className="text-sm font-medium truncate">{selectedCustomer.name}</p>
              <Badge
                variant="secondary"
                className={`text-xs ${customerTypeColors[selectedCustomer.type] || ""}`}
              >
                {selectedCustomer.type}
              </Badge>
            </div>
            <div className="flex items-center justify-between gap-2">
              <p className="text-xs text-muted-foreground flex items-center gap-1">
                <Phone className="h-3 w-3" />
                {selectedCustomer.phone}
              </p>
              <div className="text-xs font-medium text-primary flex items-center gap-1">
                <span>{selectedCustomer.loyalty_points?.toLocaleString()} pts</span>
                {loyaltyRedeemValue && (
                  <span className="text-muted-foreground">
                    ({formatKSh(pointsToKSh(selectedCustomer.loyalty_points || 0, loyaltyRedeemValue))})
                  </span>
                )}
              </div>
            </div>
          </div>
          <Button
            variant="ghost"
            size="icon"
            className="h-8 w-8"
            onClick={() => onSelectCustomer(null)}
          >
            <X className="h-4 w-4" />
          </Button>
        </div>
      </div>
    )
  }

  return (
    <div className="px-4 py-3 border-b">
      <Popover open={open} onOpenChange={setOpen}>
        <PopoverTrigger asChild>
          <Button
            variant="outline"
            role="combobox"
            aria-expanded={open}
            className="w-full justify-start text-muted-foreground"
          >
            <Search className="mr-2 h-4 w-4" />
            Search customer by name or phone...
          </Button>
        </PopoverTrigger>
        <PopoverContent className="w-[360px] p-0" align="start">
          <Command shouldFilter={false}>
            <CommandInput 
              placeholder="Enter name or phone..." 
              value={searchQuery}
              onValueChange={handleSearch}
            />
            <CommandList>
              {isSearching && (
                <div className="flex items-center justify-center py-6">
                  <Loader2 className="h-4 w-4 animate-spin text-muted-foreground" />
                </div>
              )}
              
              {!isSearching && searchQuery && searchResults.length === 0 && (
                <CommandEmpty>No customer found.</CommandEmpty>
              )}

              {!isSearching && searchResults.length > 0 && (
                <CommandGroup heading={`Results (${searchResults.length})`}>
                  {searchResults.map((customer) => (
                    <CommandItem
                      key={customer.id}
                      value={customer.id}
                      onSelect={() => {
                        onSelectCustomer({
                          id: customer.id,
                          name: customer.name,
                          phone: customer.phone || "",
                          type: customer.type,
                          loyalty_points: customer.loyalty_points || 0,
                        })
                        setOpen(false)
                        setSearchQuery("")
                        setSearchResults([])
                      }}
                    >
                      <div className="flex items-center gap-3 w-full">
                        <div className="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-muted">
                          <User className="h-4 w-4 text-muted-foreground" />
                        </div>
                        <div className="flex-1 min-w-0">
                          <p className="text-sm font-medium truncate">{customer.name}</p>
                          {customer.phone && (
                            <p className="text-xs text-muted-foreground">{customer.phone}</p>
                          )}
                        </div>
                        <Badge
                          variant="secondary"
                          className={`text-xs ${customerTypeColors[customer.type] || ""}`}
                        >
                          {customer.type}
                        </Badge>
                      </div>
                    </CommandItem>
                  ))}
                </CommandGroup>
              )}

              {/* Walk-in Customer Option */}
              {!isSearching && (
                <CommandGroup heading="Customer Type">
                  <CommandItem
                    value="walk-in"
                    onSelect={() => {
                      onSelectCustomer(null)
                      setOpen(false)
                      setSearchQuery("")
                      setSearchResults([])
                    }}
                  >
                    <div className="flex items-center gap-3 w-full">
                      <div className="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-muted">
                        <User className="h-4 w-4 text-muted-foreground" />
                      </div>
                      <div className="flex-1">
                        <p className="text-sm font-medium">Walk-in Customer</p>
                        <p className="text-xs text-muted-foreground">No customer record</p>
                      </div>
                    </div>
                  </CommandItem>
                </CommandGroup>
              )}
            </CommandList>
          </Command>
        </PopoverContent>
      </Popover>
    </div>
  )
}
</file>

<file path="components/pos/payment-panel.tsx">
"use client"

import { useState, useMemo, useRef, useEffect } from "react"
import { Button } from "@/components/ui/button"
import { Card } from "@/components/ui/card"
import { Input } from "@/components/ui/input"
import { Label } from "@/components/ui/label"
import { Separator } from "@/components/ui/separator"
import { useToast } from "@/components/ui/use-toast"
import { formatKSh, pointsToKSh, calculateNewLoyaltyBalance } from "@/lib/currency"
import { useReceiptSettings } from "@/hooks/use-receipt-settings"
import { getLoyaltySettings, getRedemptionEligibility } from "@/lib/loyalty-actions"
import { Banknote, Smartphone, CreditCard, Receipt, Check, X, Percent, ChevronDown, ChevronUp, AlertCircle, RotateCcw, Gift } from "lucide-react"
import type { SelectedCustomer } from "@/app/(dashboard)/pos/page"
import { ReceiptPreview, type SaleDetailsData } from "@/components/receipt-preview"
import {
  Dialog,
  DialogContent,
  DialogDescription,
  DialogFooter,
  DialogHeader,
  DialogTitle,
} from "@/components/ui/dialog"
import {
  Collapsible,
  CollapsibleContent,
  CollapsibleTrigger,
} from "@/components/ui/collapsible"

interface PaymentPanelProps {
  subtotal: number
  itemDiscounts: number
  cartDiscount: number
  onCartDiscountChange: (discount: number) => void
  total: number
  showPayment: boolean
  onShowPayment: (show: boolean) => void
  onCompletePayment: (receiptNumber: string, paymentMethod: string, options?: Record<string, any>) => void
  customer: SelectedCustomer | null
  branchId?: string
  fullSaleData?: SaleDetailsData | null
  onReceiptClose?: () => void
}

const paymentMethods = [
  { id: "cash", label: "Cash", icon: Banknote, color: "bg-primary/10 text-primary border-primary" },
  { id: "mpesa", label: "M-Pesa", icon: Smartphone, color: "bg-success/10 text-success border-success" },
  { id: "paybill", label: "Paybill", icon: CreditCard, color: "bg-secondary text-secondary-foreground border-secondary" },
]

export function PaymentPanel({
  subtotal,
  itemDiscounts,
  cartDiscount,
  onCartDiscountChange,
  total,
  showPayment,
  onShowPayment,
  onCompletePayment,
  customer,
  branchId,
  fullSaleData,
  onReceiptClose,
}: PaymentPanelProps) {
  const { toast } = useToast()
  const { settings: receiptSettings, loading: settingsLoading } = useReceiptSettings(branchId)
  const [selectedMethod, setSelectedMethod] = useState("cash")
  const [amountReceived, setAmountReceived] = useState("")
  const [reference, setReference] = useState("")
  const [showReceipt, setShowReceipt] = useState(false)
  const [discountInput, setDiscountInput] = useState(cartDiscount > 0 ? cartDiscount.toString() : "")
  const [showDiscountSection, setShowDiscountSection] = useState(false)
  const [isProcessing, setIsProcessing] = useState(false)
  const [receiptNumber, setReceiptNumber] = useState("")
  const [receiptLoadError, setReceiptLoadError] = useState<string | null>(null)
  const [receiptLoadingTimeout, setReceiptLoadingTimeout] = useState(false)
  const [paymentStatus, setPaymentStatus] = useState<string>("") // Visible status during payment
  const [paymentError, setPaymentError] = useState<string | null>(null) // Visible error message

  // M-Pesa specific state
  const [mpesaPhoneNumber, setMpesaPhoneNumber] = useState("")
  const [mpesaWaitingForConfirmation, setMpesaWaitingForConfirmation] = useState(false)
  const [mpesaCheckoutRequestId, setMpesaCheckoutRequestId] = useState("")
  const [mpesaSaleId, setMpesaSaleId] = useState("")
  const [mpesaPollCount, setMpesaPollCount] = useState(0)
  const [mpesaError, setMpesaError] = useState("")
  const [mpesaResult, setMpesaResult] = useState<{
    status: 'confirmed' | 'failed' | 'cancelled' | 'timeout'
    mpesaReceiptNumber?: string
    errorMessage?: string
  } | null>(null)
  const pollIntervalRef = useRef<NodeJS.Timeout | null>(null)
  const [saleIdForMpesa, setSaleIdForMpesa] = useState("")

  // Loyalty settings state
  const [loyaltySettings, setLoyaltySettings] = useState<any>(null)
  const [loyaltyLoading, setLoyaltyLoading] = useState(false)
  const [redemptionEligibility, setRedemptionEligibility] = useState<any>(null)
  const [applyRedemption, setApplyRedemption] = useState(false)
  const [pointsToRedeem, setPointsToRedeem] = useState(0)

  // Cleanup polling on unmount
  useEffect(() => {
    return () => {
      if (pollIntervalRef.current) {
        clearInterval(pollIntervalRef.current)
      }
    }
  }, [])

  // Show receipt automatically when fullSaleData is available
  useEffect(() => {
    if (fullSaleData && showPayment && !showReceipt) {
      // Close payment dialog and open receipt dialog
      setShowReceipt(true)
      onShowPayment(false)
      // Clear timeout warning when receipt successfully loads
      setReceiptLoadingTimeout(false)
    }
  }, [fullSaleData, showPayment])

  // Show timeout warning if receipt takes too long to load
  useEffect(() => {
    if (!showReceipt && showPayment && fullSaleData) {
      // Receipt is open, no timeout needed
      return
    }
    
    if (showPayment && selectedMethod === 'mpesa' && mpesaWaitingForConfirmation) {
      const timeoutId = setTimeout(() => {
        setReceiptLoadingTimeout(true)
      }, 5000)
      
      return () => clearTimeout(timeoutId)
    }
  }, [showPayment, selectedMethod, mpesaWaitingForConfirmation, fullSaleData, showReceipt])

  // Load loyalty settings
  useEffect(() => {
    async function loadLoyalty() {
      try {
        setLoyaltyLoading(true)
        const settings = await getLoyaltySettings()
        setLoyaltySettings(settings)
      } catch (error) {
        console.error('Failed to load loyalty settings:', error)
        setLoyaltySettings(null)
      } finally {
        setLoyaltyLoading(false)
      }
    }
    loadLoyalty()
  }, [])

  // Check redemption eligibility when customer or total changes
  useEffect(() => {
    async function checkRedemption() {
      if (!customer || !loyaltySettings?.redeem_enabled) {
        setRedemptionEligibility(null)
        setPointsToRedeem(0)
        setApplyRedemption(false)
        return
      }

      try {
        const eligibility = await getRedemptionEligibility(customer.id, total)
        setRedemptionEligibility(eligibility)
        // Reset redemption if customer changed
        if (pointsToRedeem > 0) {
          setPointsToRedeem(0)
        }
      } catch (error) {
        console.error('Failed to check redemption eligibility:', error)
        setRedemptionEligibility(null)
      }
    }

    checkRedemption()
  }, [customer?.id, total, loyaltySettings?.redeem_enabled])

  // Reset redemption when toggled off
  useEffect(() => {
    if (!applyRedemption) {
      setPointsToRedeem(0)
    }
  }, [applyRedemption])

  // Calculate loyalty points that will be earned
  const loyaltyPointsToEarn = useMemo(() => {
    if (!customer || !loyaltySettings || !loyaltySettings.earn_enabled) {
      return 0
    }
    
    const earnThreshold = loyaltySettings.earn_threshold_cents || 10000 // Default: 100 KSh
    const qualifyingAmount = total // Use total after discounts
    const points = Math.floor(qualifyingAmount / earnThreshold)
    return points
  }, [customer, total, loyaltySettings])

  // Calculate redemption discount
  const redemptionDiscount = useMemo(() => {
    if (!applyRedemption || pointsToRedeem <= 0 || !loyaltySettings) {
      return 0
    }
    
    return Math.round((pointsToRedeem * (loyaltySettings.redeem_value_cents || 50)) / 100)
  }, [applyRedemption, pointsToRedeem, loyaltySettings])

  // Calculate final total with redemption
  const finalTotal = Math.max(0, total - redemptionDiscount)

  const startMpesaPolling = (checkoutRequestId: string) => {
    let pollCount = 0
    const maxPolls = 90 // 3 minutes at 2-second intervals
    
    if (pollIntervalRef.current) {
      clearInterval(pollIntervalRef.current)
    }

    pollIntervalRef.current = setInterval(async () => {
      pollCount++
      setMpesaPollCount(pollCount)

      try {
        const response = await fetch(
          `/api/mpesa/status?checkoutRequestId=${encodeURIComponent(checkoutRequestId)}`
        )
        
        if (!response.ok) {
          console.error('Status check failed:', response.status)
          return
        }

        const data = await response.json()

        if (data.success) {
          if (data.isConfirmed) {
            // Payment confirmed!
            if (pollIntervalRef.current) {
              clearInterval(pollIntervalRef.current)
              pollIntervalRef.current = null
            }
            
            setMpesaWaitingForConfirmation(false)
            setMpesaResult({
              status: 'confirmed',
              mpesaReceiptNumber: data.mpesaReceiptNumber
            })
            
            // Call immediately - no artificial delay, receipt will auto-show via useEffect
            onCompletePayment(receiptNumber, 'mpesa', {
              checkoutRequestId,
              saleId: saleIdForMpesa,
              skipSaleCreation: true // Sale already created as pending
            })
            
            toast({
              title: 'Payment Confirmed',
              description: `M-Pesa Receipt: ${data.mpesaReceiptNumber || 'N/A'}`,
              variant: 'default'
            })
          } else if (data.isFailed) {
            // Payment failed
            if (pollIntervalRef.current) {
              clearInterval(pollIntervalRef.current)
              pollIntervalRef.current = null
            }
            
            setMpesaWaitingForConfirmation(false)
            setMpesaResult({
              status: 'failed',
              errorMessage: data.errorMessage || 'Payment failed'
            })
            
            toast({
              title: 'Payment Failed',
              description: data.errorMessage || 'M-Pesa payment was not successful',
              variant: 'destructive'
            })
          }
          // If isPending, keep polling
        }
      } catch (error) {
        console.error('M-Pesa polling error:', error)
      }

      // Stop polling after max attempts
      if (pollCount >= maxPolls) {
        if (pollIntervalRef.current) {
          clearInterval(pollIntervalRef.current)
          pollIntervalRef.current = null
        }
        
        setMpesaWaitingForConfirmation(false)
        setMpesaResult({
          status: 'timeout',
          errorMessage: 'Payment confirmation timeout. Please check M-Pesa on customer phone.'
        })
        
        toast({
          title: 'Timeout',
          description: 'No response from M-Pesa after 3 minutes',
          variant: 'destructive'
        })
      }
    }, 2000) // Poll every 2 seconds
  }

  const handleMpesaSend = async () => {
    if (!mpesaPhoneNumber.trim()) {
      setMpesaError('Please enter customer phone number')
      toast({
        title: 'Error',
        description: 'Phone number is required',
        variant: 'destructive'
      })
      return
    }

    setIsProcessing(true)
    setMpesaError('')

    // Generate receipt number once
    const newReceiptNumber = `RCP-${Date.now().toString().slice(-8)}`
    setReceiptNumber(newReceiptNumber)

    try {
      // Call parent to create sale and get saleId
      // Parent will handle the actual sale creation
      onCompletePayment(newReceiptNumber, 'mpesa', {
        mpesaPhone: mpesaPhoneNumber,
        isInitialStkPush: true, // Signal that this is the initial STK Push
        redemption: applyRedemption && pointsToRedeem > 0 ? {
          pointsToRedeem,
          discountApplied: redemptionDiscount
        } : undefined,
        onSaleCreated: (saleId: string) => {
          setSaleIdForMpesa(saleId)
        },
        onCheckoutId: (checkoutId: string) => {
          setMpesaCheckoutRequestId(checkoutId)
          setMpesaWaitingForConfirmation(true)
          startMpesaPolling(checkoutId)
        },
        onError: (error: string) => {
          setMpesaError(error)
          toast({
            title: 'Error',
            description: error,
            variant: 'destructive'
          })
        }
      })
    } catch (error) {
      const message = error instanceof Error ? error.message : 'Failed to send STK Push'
      setMpesaError(message)
      toast({
        title: 'Error',
        description: message,
        variant: 'destructive'
      })
    } finally {
      setIsProcessing(false)
    }
  }

  const handleMpesaRetry = () => {
    setMpesaResult(null)
    setMpesaCheckoutRequestId('')
    setMpesaSaleId('')
    setMpesaPollCount(0)
    setMpesaPhoneNumber('')
    // Back to initial state - user can try again or choose different payment
  }

  const handlePayment = async () => {
    // Prevent duplicate clicks during processing
    if (isProcessing) return
    
    if (selectedMethod === 'mpesa') {
      // M-Pesa flow handled separately
      await handleMpesaSend()
      return
    }

    // Non-M-Pesa flow (cash, paybill, redeem, etc)
    setIsProcessing(true)
    setPaymentStatus("")
    setPaymentError(null)
    const newReceiptNumber = `RCP-${Date.now().toString().slice(-8)}`
    setReceiptNumber(newReceiptNumber)
    
    // Simulate payment processing delay
    await new Promise(resolve => setTimeout(resolve, 500))
    
    // Regular payment method with optional legacy redemption
    try {
      setPaymentStatus("Creating sale...")
      console.log('[PAYMENT] Starting payment processing')
      
      await onCompletePayment(newReceiptNumber, selectedMethod as any, {
        redemption: applyRedemption && pointsToRedeem > 0 ? {
          pointsToRedeem,
          discountApplied: redemptionDiscount
        } : undefined
      })
      
      setPaymentStatus("")
    } catch (error) {
      const errorMessage = error instanceof Error ? error.message : 'Unknown error occurred'
      console.error('[PAYMENT] Error during payment:', errorMessage)
      setPaymentError(errorMessage)
      setPaymentStatus("")
      
      toast({
        title: 'Payment Error',
        description: errorMessage,
        variant: 'destructive',
      })
    } finally {
      setIsProcessing(false)
    }
  }

  const handleComplete = () => {
    // Clean up polling
    if (pollIntervalRef.current) {
      clearInterval(pollIntervalRef.current)
      pollIntervalRef.current = null
    }

    // Close receipt dialog
    setShowReceipt(false)
    
    // Close payment dialog
    onShowPayment(false)
    
    // Clear all payment state for next transaction
    setAmountReceived("")
    setReference("")
    setSelectedMethod("cash")
    setDiscountInput("")
    setReceiptNumber("")
    
    // Clear M-Pesa state
    setMpesaPhoneNumber("")
    setMpesaWaitingForConfirmation(false)
    setMpesaCheckoutRequestId("")
    setMpesaSaleId("")
    setMpesaPollCount(0)
    setMpesaError("")
    setMpesaResult(null)
    setSaleIdForMpesa("")
    
    // Notify parent that receipt viewing is complete
    onReceiptClose?.()
  }

  const applyCartDiscount = () => {
    const value = parseFloat(discountInput) || 0
    onCartDiscountChange(value)
  }

  const totalDiscount = itemDiscounts + cartDiscount
  const change = selectedMethod === "cash" && amountReceived 
    ? parseFloat(amountReceived) - total 
    : 0

  return (
    <>
      <div className="p-4 space-y-4 border-t bg-gradient-to-t from-muted/30 to-card">
        {/* Discount Section */}
        <Collapsible open={showDiscountSection} onOpenChange={setShowDiscountSection}>
          <CollapsibleTrigger asChild>
            <Button variant="ghost" size="sm" className="w-full justify-between h-8 px-2">
              <span className="flex items-center gap-2 text-sm">
                <Percent className="h-3.5 w-3.5" />
                Cart Discount
              </span>
              {showDiscountSection ? (
                <ChevronUp className="h-4 w-4" />
              ) : (
                <ChevronDown className="h-4 w-4" />
              )}
            </Button>
          </CollapsibleTrigger>
          <CollapsibleContent>
            <div className="flex gap-2 mt-2">
              <Input
                type="number"
                placeholder="Discount amount (KSh)"
                value={discountInput}
                onChange={(e) => setDiscountInput(e.target.value)}
                className="flex-1"
              />
              <Button size="sm" onClick={applyCartDiscount}>
                Apply
              </Button>
              {cartDiscount > 0 && (
                <Button
                  size="sm"
                  variant="outline"
                  onClick={() => {
                    onCartDiscountChange(0)
                    setDiscountInput("")
                  }}
                >
                  Clear
                </Button>
              )}
            </div>
          </CollapsibleContent>
        </Collapsible>

        {/* Totals */}
        <div className="space-y-2 p-3 rounded-lg bg-background border">
          <div className="flex justify-between text-sm">
            <span className="text-muted-foreground">Subtotal</span>
            <span>{formatKSh(subtotal)}</span>
          </div>
          {totalDiscount > 0 && (
            <>
              {itemDiscounts > 0 && (
                <div className="flex justify-between text-sm text-success">
                  <span>Item Discounts</span>
                  <span>-{formatKSh(itemDiscounts)}</span>
                </div>
              )}
              {cartDiscount > 0 && (
                <div className="flex justify-between text-sm text-success">
                  <span>Cart Discount</span>
                  <span>-{formatKSh(cartDiscount)}</span>
                </div>
              )}
            </>
          )}
          <Separator />
          <div className="flex justify-between text-xl font-bold pt-1">
            <span>Total</span>
            <span className="text-primary">{formatKSh(total)}</span>
          </div>
          
          {/* Redemption Section */}
          {customer && loyaltySettings?.redeem_enabled && (
            <>
              {redemptionEligibility?.eligible ? (
                <div className="pt-2 space-y-2 bg-blue-50 rounded p-2 border border-blue-100">
                  <div className="flex items-center gap-2">
                    <input
                      type="checkbox"
                      id="apply-redemption"
                      checked={applyRedemption}
                      onChange={(e) => setApplyRedemption(e.target.checked)}
                      className="w-4 h-4 cursor-pointer"
                    />
                    <label htmlFor="apply-redemption" className="text-sm font-medium cursor-pointer flex-1">
                      Redeem Points
                    </label>
                    <span className="text-xs text-muted-foreground">
                      {redemptionEligibility.currentBalance} available
                    </span>
                  </div>
                  
                  {applyRedemption && (
                    <div className="space-y-2 border-t border-blue-100 pt-2">
                      <div className="text-xs text-muted-foreground">
                        Max: {redemptionEligibility.maxRedeemablePoints.toLocaleString()} pts ({formatKSh(redemptionEligibility.maxRedeemableDiscount)})
                      </div>
                      
                      <div className="flex gap-2">
                        <input
                          type="number"
                          min="0"
                          max={redemptionEligibility.maxRedeemablePoints}
                          value={pointsToRedeem}
                          onChange={(e) => {
                            const value = Math.min(
                              parseInt(e.target.value) || 0,
                              redemptionEligibility.maxRedeemablePoints
                            )
                            setPointsToRedeem(value)
                          }}
                          placeholder="Points to redeem"
                          className="flex-1 px-2 py-1 border rounded text-sm"
                        />
                        <Button
                          size="sm"
                          variant="outline"
                          onClick={() => setPointsToRedeem(redemptionEligibility.maxRedeemablePoints)}
                          className="text-xs"
                        >
                          Max
                        </Button>
                      </div>
                      
                      {pointsToRedeem > 0 && (
                        <div className="text-sm font-medium text-primary">
                          -{formatKSh(redemptionDiscount)} discount
                        </div>
                      )}
                    </div>
                  )}
                </div>
              ) : (
                <div className="pt-2 px-2 py-2 rounded bg-amber-50 border border-amber-200">
                  <div className="flex items-start gap-2">
                    <AlertCircle className="h-4 w-4 text-amber-600 flex-shrink-0 mt-0.5" />
                    <div className="text-xs text-amber-800">
                      <p className="font-medium mb-1">Cannot Redeem Points</p>
                      <p className="text-amber-700">
                        {redemptionEligibility?.reason || 'Not eligible for redemption on this purchase'}
                      </p>
                    </div>
                  </div>
                </div>
              )}
            </>
          )}
          
          {/* Loyalty Points Preview */}
          {customer && loyaltySettings?.earn_enabled && loyaltyPointsToEarn > 0 && (
            <div className="flex justify-between text-sm pt-1 text-primary items-center gap-2">
              <div className="flex items-center gap-1">
                <Gift className="h-4 w-4" />
                <span>Will Earn</span>
              </div>
              <div className="flex items-center gap-1">
                <span className="font-semibold">{loyaltyPointsToEarn.toLocaleString()} pts</span>
                <span className="text-xs text-muted-foreground">
                  ({formatKSh(pointsToKSh(loyaltyPointsToEarn, loyaltySettings.redeem_value_cents))})
                </span>
              </div>
            </div>
          )}
          
          {/* Loyalty Balance Preview */}
          {customer && loyaltySettings && (loyaltyPointsToEarn > 0 || pointsToRedeem > 0) && (
            <div className="pt-2 border-t border-primary/20 text-xs text-primary/80 space-y-1">
              <div className="flex justify-between">
                <span>Current Balance</span>
                <span className="font-medium">{(customer.loyalty_points || 0).toLocaleString()} pts</span>
              </div>
              {pointsToRedeem > 0 && (
                <div className="flex justify-between text-red-600">
                  <span>- Redeeming</span>
                  <span className="font-medium">{pointsToRedeem.toLocaleString()} pts</span>
                </div>
              )}
              {loyaltyPointsToEarn > 0 && (
                <div className="flex justify-between text-green-600">
                  <span>+ Earning</span>
                  <span className="font-medium">{loyaltyPointsToEarn.toLocaleString()} pts</span>
                </div>
              )}
              <Separator className="my-1" />
              <div className="flex justify-between font-semibold text-primary">
                <span>New Balance</span>
                <span>{calculateNewLoyaltyBalance(customer.loyalty_points || 0, pointsToRedeem, loyaltyPointsToEarn).toLocaleString()} pts</span>
              </div>
            </div>
          )}
          
          {/* Final Total After Redemption */}
          {redemptionDiscount > 0 && (
            <>
              <Separator className="my-1" />
              <div className="flex justify-between text-xl font-bold text-primary">
                <span>Final Total</span>
                <span>{formatKSh(finalTotal)}</span>
              </div>
            </>
          )}
        </div>

        <Button
          className="w-full h-12 text-lg font-semibold"
          size="lg"
          disabled={total === 0}
          onClick={() => onShowPayment(true)}
        >
          <Receipt className="mr-2 h-5 w-5" />
          Checkout
        </Button>
      </div>

      {/* Payment Dialog */}
      <Dialog open={showPayment && !showReceipt} onOpenChange={onShowPayment}>
        <DialogContent className="sm:max-w-md">
          <DialogHeader>
            <DialogTitle className="flex items-center gap-2">
              <div className="h-8 w-8 rounded-lg bg-primary/10 flex items-center justify-center">
                <Receipt className="h-4 w-4 text-primary" />
              </div>
              Complete Payment
            </DialogTitle>
            <DialogDescription>
              {customer && (
                <div className="text-sm space-y-1 mb-2">
                  <div>Customer: {customer.name}</div>
                  {loyaltySettings && (
                    <div className="text-xs text-muted-foreground">
                      Loyalty Balance: {customer.loyalty_points?.toLocaleString()} pts = {formatKSh(pointsToKSh(customer.loyalty_points || 0, loyaltySettings.redeem_value_cents))}
                    </div>
                  )}
                </div>
              )}
            </DialogDescription>
            
            {/* Visible payment status/error area */}
            {isProcessing && paymentStatus && (
              <div className="bg-blue-50 dark:bg-blue-950/30 rounded-lg p-3 text-sm text-blue-900 dark:text-blue-100 border border-blue-200 dark:border-blue-800">
                <div className="flex items-center gap-2">
                  <div className="h-2 w-2 rounded-full bg-blue-500 animate-pulse" />
                  {paymentStatus}
                </div>
              </div>
            )}
            
            {paymentError && (
              <div className="bg-destructive/10 rounded-lg p-3 text-sm text-destructive border border-destructive/20">
                <div className="font-semibold mb-1">Payment Error</div>
                <div>{paymentError}</div>
              </div>
            )}
          </DialogHeader>

          {/* Redemption Controls - In Dialog (Primary UI for checkout) */}
          {customer && loyaltySettings?.redeem_enabled && (
            <div className="bg-blue-50 dark:bg-blue-950/30 rounded-lg p-3 space-y-2 border border-blue-200 dark:border-blue-800">
              <label className="text-sm font-semibold text-blue-900 dark:text-blue-100 flex items-center gap-2 cursor-pointer">
                <input
                  type="checkbox"
                  id="dialog-apply-redemption"
                  checked={applyRedemption}
                  onChange={(e) => setApplyRedemption(e.target.checked)}
                  className="w-4 h-4 cursor-pointer"
                />
                <span>Redeem Points on This Purchase</span>
              </label>

              {redemptionEligibility?.eligible ? (
                applyRedemption ? (
                  <div className="space-y-2 border-t border-blue-200 dark:border-blue-800 pt-2">
                    <div className="text-xs text-blue-700 dark:text-blue-300">
                      <div className="flex justify-between mb-1">
                        <span>Available:</span>
                        <span className="font-medium">{redemptionEligibility.currentBalance.toLocaleString()} pts</span>
                      </div>
                      <div className="flex justify-between">
                        <span>Max Redeemable:</span>
                        <span className="font-medium">{redemptionEligibility.maxRedeemablePoints.toLocaleString()} pts ({formatKSh(redemptionEligibility.maxRedeemableDiscount)})</span>
                      </div>
                    </div>

                    <div className="flex gap-2 mt-2">
                      <input
                        type="number"
                        min="0"
                        max={redemptionEligibility.maxRedeemablePoints}
                        value={pointsToRedeem}
                        onChange={(e) => {
                          const value = Math.min(
                            parseInt(e.target.value) || 0,
                            redemptionEligibility.maxRedeemablePoints
                          )
                          setPointsToRedeem(value)
                        }}
                        placeholder="Points to redeem"
                        className="flex-1 px-2 py-1.5 border rounded text-sm bg-white dark:bg-slate-800"
                      />
                      <Button
                        size="sm"
                        variant="outline"
                        onClick={() => setPointsToRedeem(redemptionEligibility.maxRedeemablePoints)}
                        className="text-xs whitespace-nowrap"
                      >
                        Use Max
                      </Button>
                    </div>

                    {pointsToRedeem > 0 && (
                      <div className="text-sm font-semibold text-primary">
                        Discount: {formatKSh(redemptionDiscount)}
                      </div>
                    )}
                  </div>
                ) : (
                  <div className="text-xs text-blue-700 dark:text-blue-300">
                    <span>{redemptionEligibility.currentBalance.toLocaleString()} pts available</span>
                  </div>
                )
              ) : (
                <div className="text-xs text-amber-700 dark:text-amber-300 flex items-start gap-2">
                  <AlertCircle className="h-3.5 w-3.5 flex-shrink-0 mt-0.5" />
                  <span>{redemptionEligibility?.reason || 'Not eligible for redemption on this purchase'}</span>
                </div>
              )}
            </div>
          )}

          {/* Totals & Loyalty Summary Section */}
          <div className="bg-muted/30 rounded-lg p-3 space-y-2 text-sm">
            <div className="flex justify-between">
              <span className="text-muted-foreground">Subtotal</span>
              <span className="font-medium">{formatKSh(subtotal)}</span>
            </div>
            {itemDiscounts > 0 && (
              <div className="flex justify-between text-destructive">
                <span className="text-muted-foreground">Item Discounts</span>
                <span>-{formatKSh(itemDiscounts)}</span>
              </div>
            )}
            {cartDiscount > 0 && (
              <div className="flex justify-between text-destructive">
                <span className="text-muted-foreground">Cart Discount</span>
                <span>-{formatKSh(cartDiscount)}</span>
              </div>
            )}
            
            {/* Loyalty Earning Preview */}
            {customer && loyaltySettings?.earn_enabled && loyaltyPointsToEarn > 0 && (
              <div className="flex justify-between text-primary border-t border-border pt-2">
                <span className="text-muted-foreground flex items-center gap-1">
                  <Gift className="h-4 w-4" />
                  Will Earn
                </span>
                <span className="font-semibold">
                  {loyaltyPointsToEarn.toLocaleString()} pts 
                  ({formatKSh(pointsToKSh(loyaltyPointsToEarn, loyaltySettings.redeem_value_cents))})
                </span>
              </div>
            )}
            
            {/* Loyalty Redemption Preview */}
            {applyRedemption && pointsToRedeem > 0 && (
              <div className="flex justify-between text-primary">
                <span className="text-muted-foreground flex items-center gap-1">
                  <Gift className="h-4 w-4" />
                  Redeem
                </span>
                <span className="font-semibold">-{pointsToRedeem.toLocaleString()} pts (-{formatKSh(redemptionDiscount)})</span>
              </div>
            )}
            
            {/* Loyalty Balance Preview - Dialog */}
            {customer && loyaltySettings && (loyaltyPointsToEarn > 0 || pointsToRedeem > 0) && (
              <>
                <Separator className="my-2" />
                <div className="text-xs text-primary/80 space-y-1">
                  <div className="flex justify-between">
                    <span className="text-muted-foreground">Current Balance</span>
                    <span className="font-medium">{(customer.loyalty_points || 0).toLocaleString()} pts</span>
                  </div>
                  {pointsToRedeem > 0 && (
                    <div className="flex justify-between text-red-600">
                      <span className="text-muted-foreground">- Redeeming</span>
                      <span className="font-medium">{pointsToRedeem.toLocaleString()} pts</span>
                    </div>
                  )}
                  {loyaltyPointsToEarn > 0 && (
                    <div className="flex justify-between text-green-600">
                      <span className="text-muted-foreground">+ Earning</span>
                      <span className="font-medium">{loyaltyPointsToEarn.toLocaleString()} pts</span>
                    </div>
                  )}
                  <Separator className="my-1" />
                  <div className="flex justify-between font-semibold text-primary">
                    <span>New Balance</span>
                    <span>{calculateNewLoyaltyBalance(customer.loyalty_points || 0, pointsToRedeem, loyaltyPointsToEarn).toLocaleString()} pts</span>
                  </div>
                </div>
              </>
            )}
            
            <Separator className="my-2" />
            
            {/* Final Total */}
            <div className="flex justify-between items-center">
              <span className="font-bold text-base">Total to Pay</span>
              <span className="font-bold text-2xl text-primary">{formatKSh(finalTotal)}</span>
            </div>
          </div>

          <div className="space-y-4 py-4">
            <div className="grid grid-cols-3 gap-2">
              {paymentMethods.map((method) => (
                <Card
                  key={method.id}
                  className={`p-4 cursor-pointer text-center transition-all ${
                    selectedMethod === method.id
                      ? `${method.color} border-2`
                      : "hover:border-muted-foreground/30"
                  }`}
                  onClick={() => setSelectedMethod(method.id)}
                >
                  <method.icon className={`h-6 w-6 mx-auto mb-2 ${
                    selectedMethod === method.id ? "" : "text-muted-foreground"
                  }`} />
                  <span className={`text-sm font-medium`}>
                    {method.label}
                  </span>
                </Card>
              ))}
            </div>

            {selectedMethod === "cash" && (
              <div className="space-y-3">
                <div className="space-y-2">
                  <Label htmlFor="amount">Amount Received</Label>
                  <Input
                    id="amount"
                    type="number"
                    placeholder="Enter amount"
                    value={amountReceived}
                    onChange={(e) => setAmountReceived(e.target.value)}
                    className="text-lg h-12"
                  />
                </div>
                {/* Quick amounts */}
                <div className="grid grid-cols-4 gap-2">
                  {[total, Math.ceil(total / 100) * 100, Math.ceil(total / 500) * 500, Math.ceil(total / 1000) * 1000].map((amount, i) => (
                    <Button
                      key={i}
                      variant="outline"
                      size="sm"
                      onClick={() => setAmountReceived(amount.toString())}
                      className="text-xs"
                    >
                      {formatKSh(amount)}
                    </Button>
                  ))}
                </div>
                {parseFloat(amountReceived) >= total && (
                  <div className="flex justify-between p-4 rounded-lg bg-success/10 text-success border border-success/20">
                    <span className="font-medium">Change to Return</span>
                    <span className="font-bold text-lg">{formatKSh(change)}</span>
                  </div>
                )}
              </div>
            )}

            {selectedMethod === "mpesa" && !mpesaWaitingForConfirmation && !mpesaResult && (
              <div className="space-y-3">
                <div className="space-y-2">
                  <Label htmlFor="mpesa-phone">Customer Phone Number</Label>
                  <Input
                    id="mpesa-phone"
                    type="tel"
                    placeholder="0712345678 or 254712345678"
                    value={mpesaPhoneNumber}
                    onChange={(e) => setMpesaPhoneNumber(e.target.value)}
                    className="text-lg h-12"
                    disabled={isProcessing}
                  />
                  <p className="text-xs text-muted-foreground">
                    Customer will see M-Pesa prompt on their phone
                  </p>
                </div>
                {mpesaError && (
                  <div className="p-3 rounded-lg bg-destructive/10 border border-destructive/20 flex gap-2">
                    <AlertCircle className="h-5 w-5 text-destructive flex-shrink-0 mt-0.5" />
                    <p className="text-sm text-destructive">{mpesaError}</p>
                  </div>
                )}
              </div>
            )}

            {selectedMethod === "mpesa" && mpesaWaitingForConfirmation && (
              <div className="space-y-3">
                <div className="p-4 rounded-lg bg-success/10 border border-success text-center">
                  <p className="text-success font-semibold text-lg">STK Push Sent! ✓</p>
                  <p className="text-sm text-muted-foreground mt-2">
                    Customer phone: {mpesaPhoneNumber}
                  </p>
                </div>
                
                <div className="space-y-2">
                  <p className="text-sm font-medium">Payment Status</p>
                  <div className="p-3 rounded-lg bg-muted space-y-2">
                    <div className="flex items-center gap-2">
                      <div className="h-2 w-2 rounded-full bg-blue-500 animate-pulse" />
                      <p className="text-sm">Waiting for M-Pesa confirmation...</p>
                    </div>
                    <p className="text-xs text-muted-foreground">{mpesaPollCount}s elapsed</p>
                  </div>
                </div>

                <div className="bg-blue-50 dark:bg-blue-950/20 border border-blue-200 dark:border-blue-800 rounded-lg p-3 text-sm">
                  <p className="font-medium text-blue-900 dark:text-blue-100">What happens next?</p>
                  <ul className="mt-2 text-xs text-blue-800 dark:text-blue-200 space-y-1 ml-2">
                    <li>• Customer enters M-Pesa PIN on their phone</li>
                    <li>• We receive confirmation automatically</li>
                    <li>• Receipt will show when confirmed</li>
                  </ul>
                </div>
              </div>
            )}

            {selectedMethod === "mpesa" && mpesaResult?.status === 'confirmed' && (
              <div className="space-y-3">
                <div className="p-4 rounded-lg bg-success/10 border border-success text-center">
                  <div className="flex justify-center mb-2">
                    <Check className="h-8 w-8 text-success" />
                  </div>
                  <p className="text-success font-semibold text-lg">Payment Confirmed!</p>
                  {mpesaResult.mpesaReceiptNumber && (
                    <p className="text-sm text-muted-foreground mt-2">
                      M-Pesa Receipt: {mpesaResult.mpesaReceiptNumber}
                    </p>
                  )}
                </div>
              </div>
            )}

            {selectedMethod === "mpesa" && mpesaResult?.status === 'failed' && (
              <div className="space-y-3">
                <div className="p-4 rounded-lg bg-destructive/10 border border-destructive/30 text-center">
                  <div className="flex justify-center mb-2">
                    <X className="h-8 w-8 text-destructive" />
                  </div>
                  <p className="text-destructive font-semibold text-lg">Payment Failed</p>
                  <p className="text-sm text-muted-foreground mt-2">
                    {mpesaResult.errorMessage || 'M-Pesa payment was not successful'}
                  </p>
                </div>
                <Button
                  variant="outline"
                  className="w-full"
                  onClick={handleMpesaRetry}
                >
                  <RotateCcw className="h-4 w-4 mr-2" />
                  Try Again
                </Button>
                <Button
                  variant="secondary"
                  className="w-full"
                  onClick={() => {
                    setSelectedMethod("cash")
                    handleMpesaRetry()
                  }}
                >
                  Use Different Payment Method
                </Button>
              </div>
            )}

            {selectedMethod === "mpesa" && mpesaResult?.status === 'timeout' && (
              <div className="space-y-3">
                <div className="p-4 rounded-lg bg-yellow-50 dark:bg-yellow-950/20 border border-yellow-200 dark:border-yellow-800 text-center">
                  <div className="flex justify-center mb-2">
                    <AlertCircle className="h-8 w-8 text-yellow-700 dark:text-yellow-400" />
                  </div>
                  <p className="font-semibold text-lg text-yellow-900 dark:text-yellow-100">Payment Timeout</p>
                  <p className="text-sm text-yellow-800 dark:text-yellow-200 mt-2">
                    {mpesaResult.errorMessage || 'No response from M-Pesa'}
                  </p>
                </div>
                <Button
                  variant="outline"
                  className="w-full"
                  onClick={handleMpesaRetry}
                >
                  <RotateCcw className="h-4 w-4 mr-2" />
                  Try Again
                </Button>
              </div>
            )}

            {selectedMethod === "paybill" && (
              <div className="space-y-3">
                <div className="p-3 rounded-lg bg-secondary/50 border text-sm">
                  <p className="font-medium">Paybill: 888880</p>
                  <p className="text-muted-foreground">Account: WINNMATT</p>
                </div>
                <div className="space-y-2">
                  <Label htmlFor="reference">Reference Number</Label>
                  <Input
                    id="reference"
                    placeholder="Enter reference number"
                    value={reference}
                    onChange={(e) => setReference(e.target.value)}
                  />
                </div>
              </div>
            )}
          </div>

          <DialogFooter className="gap-2 sm:gap-0">
            <Button 
              variant="outline" 
              onClick={() => {
                if (pollIntervalRef.current) {
                  clearInterval(pollIntervalRef.current)
                  pollIntervalRef.current = null
                }
                setMpesaWaitingForConfirmation(false)
                setMpesaResult(null)
                onShowPayment(false)
              }} 
              disabled={isProcessing && !mpesaWaitingForConfirmation}
            >
              Cancel
            </Button>

            {!mpesaWaitingForConfirmation && !mpesaResult && selectedMethod === 'mpesa' && (
              <Button
                onClick={handlePayment}
                disabled={isProcessing || !mpesaPhoneNumber.trim()}
                className="min-w-[140px]"
              >
                {isProcessing ? (
                  <>
                    <div className="h-4 w-4 mr-2 animate-spin rounded-full border-2 border-current border-t-transparent" />
                    Sending...
                  </>
                ) : (
                  <>
                    <Smartphone className="h-4 w-4 mr-2" />
                    Send STK Push
                  </>
                )}
              </Button>
            )}

            {mpesaWaitingForConfirmation && selectedMethod === 'mpesa' && (
              <Button disabled className="min-w-[140px]">
                <div className="h-4 w-4 mr-2 animate-spin rounded-full border-2 border-current border-t-transparent" />
                Waiting...
              </Button>
            )}

            {mpesaResult && selectedMethod === 'mpesa' && mpesaResult.status === 'confirmed' && (
              <Button disabled className="min-w-[140px] bg-success text-success-foreground">
                <Check className="h-4 w-4 mr-2" />
                Confirmed
              </Button>
            )}

            {selectedMethod !== 'mpesa' && (
              <Button
                onClick={handlePayment}
                disabled={
                  isProcessing ||
                  (selectedMethod === "cash" && parseFloat(amountReceived) < total) ||
                  (selectedMethod === "paybill" && !reference)
                }
                className="min-w-[140px]"
              >
                {isProcessing ? (
                  <>
                    <div className="h-4 w-4 mr-2 animate-spin rounded-full border-2 border-current border-t-transparent" />
                    Processing...
                  </>
                ) : (
                  <>
                    <Check className="h-4 w-4 mr-2" />
                    Complete Sale
                  </>
                )}
              </Button>
            )}
          </DialogFooter>
        </DialogContent>
      </Dialog>

      {/* Receipt Dialog */}
      <Dialog open={showReceipt} onOpenChange={(open) => {
        if (!open) {
          // User is closing receipt dialog
          handleComplete()
        }
      }}>
        <DialogContent className="sm:max-w-lg max-h-[90vh] overflow-y-auto">
          {receiptLoadError ? (
            // Error state - loading took too long or failed
            <div className="text-center space-y-4 py-6">
              <div className="h-16 w-16 rounded-full bg-destructive/10 mx-auto flex items-center justify-center">
                <AlertCircle className="h-8 w-8 text-destructive" />
              </div>
              <div>
                <h3 className="text-lg font-bold text-destructive">Receipt Not Ready</h3>
                <p className="text-sm text-muted-foreground mt-2">
                  {receiptLoadError}
                </p>
              </div>

              <div className="bg-muted/50 rounded-lg p-4 text-left space-y-2 text-sm">
                <div className="space-y-1">
                  <p className="font-medium">What you can do:</p>
                  <ul className="text-xs text-muted-foreground space-y-1 ml-4">
                    <li>• The sale may have been completed and saved</li>
                    <li>• Receipt #: {receiptNumber}</li>
                    <li>• You can close this and check recent sales</li>
                  </ul>
                </div>
              </div>

              <div className="flex gap-2 pt-2">
                <Button
                  variant="outline"
                  onClick={() => {
                    setReceiptLoadError(null)
                    setReceiptLoadingTimeout(false)
                    // Try to at least show partial receipt if we have item data
                  }}
                  className="flex-1"
                >
                  <RotateCcw className="h-4 w-4 mr-2" />
                  Retry
                </Button>
                <Button
                  onClick={() => handleComplete()}
                  className="flex-1"
                >
                  <X className="h-4 w-4 mr-2" />
                  Close & Continue
                </Button>
              </div>
            </div>
          ) : fullSaleData ? (
            // Show full receipt with items when data is available
            <div className="py-4">
              <ReceiptPreview
                saleData={fullSaleData}
                showPrintButton={true}
                showCloseButton={true}
                onPrint={() => {
                  // Print will be handled by the component's window.print()
                }}
                onClose={() => {
                  // Close the receipt dialog and reset payment state
                  handleComplete()
                }}
              />
            </div>
          ) : (
            // Show loading state while waiting for full sale data (with timeout warning)
            <div className="text-center space-y-4 py-6 max-h-[70vh] overflow-y-auto">
              <div className="h-16 w-16 rounded-full bg-success/10 mx-auto flex items-center justify-center">
                <Check className="h-8 w-8 text-success" />
              </div>
              <div>
                <h3 className="text-xl font-bold">Processing Payment...</h3>
                <p className="text-success font-mono text-lg font-bold mt-2">
                  Receipt #{receiptNumber}
                </p>
              </div>
              
              <div className="bg-muted/50 rounded-lg p-4 text-left space-y-2 text-sm">
                <div className="flex items-center gap-2">
                  <div className="h-2 w-2 rounded-full bg-blue-500 animate-pulse" />
                  <p className="text-sm text-muted-foreground">Preparing your receipt...</p>
                </div>
                {receiptLoadingTimeout && (
                  <p className="text-xs text-amber-600 pt-2 border-t border-orange-200">
                    ⚠️ Taking longer than expected. Your sale may still have been saved. Waiting a bit more...
                  </p>
                )}
              </div>

              {receiptLoadingTimeout && (
                <Button
                  variant="outline"
                  onClick={() => handleComplete()}
                  className="w-full"
                >
                  <X className="h-4 w-4 mr-2" />
                  Close & Continue (Sale Likely Saved)
                </Button>
              )}
            </div>
          )}
        </DialogContent>
      </Dialog>
    </>
  )
}
</file>

<file path="components/pos/product-grid.tsx">
"use client"

import { Card } from "@/components/ui/card"
import { Badge } from "@/components/ui/badge"
import { formatKSh } from "@/lib/mock-data"
import { Plus, AlertTriangle } from "lucide-react"
import { ScrollArea } from "@/components/ui/scroll-area"

interface Product {
  id: string
  name: string
  sku: string
  category: string
  price: number
  stock: { [key: string]: number }
}

interface ProductGridProps {
  products: Product[]
  onAddToCart: (productId: string) => void
  isWholesale: boolean
}

export function ProductGrid({ products, onAddToCart, isWholesale }: ProductGridProps) {
  const getStockStatus = (product: Product) => {
    const totalStock = Object.values(product.stock).reduce((a, b) => a + b, 0)
    if (totalStock === 0) return { status: "out", label: "Out of Stock", color: "destructive" }
    if (totalStock < 20) return { status: "low", label: `${totalStock} left`, color: "warning" }
    return { status: "ok", label: `${totalStock} in stock`, color: "secondary" }
  }

  return (
    <ScrollArea className="flex-1">
      <div className="p-4">
        <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-3">
          {products.map((product) => {
            const stockInfo = getStockStatus(product)
            const displayPrice = isWholesale ? Math.round(product.price * 0.85) : product.price

            return (
              <Card
                key={product.id}
                className={`group relative overflow-hidden cursor-pointer transition-all hover:shadow-md hover:border-primary/50 ${
                  stockInfo.status === "out" ? "opacity-60" : ""
                }`}
                onClick={() => stockInfo.status !== "out" && onAddToCart(product.id)}
              >
                <div className="p-3">
                  <div className="aspect-square rounded-lg bg-muted/50 mb-3 flex items-center justify-center relative overflow-hidden">
                    <span className="text-2xl font-bold text-muted-foreground/30">
                      {product.name.charAt(0)}
                    </span>
                    {stockInfo.status !== "out" && (
                      <div className="absolute inset-0 bg-primary/10 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                        <div className="h-10 w-10 rounded-full bg-primary flex items-center justify-center">
                          <Plus className="h-5 w-5 text-primary-foreground" />
                        </div>
                      </div>
                    )}
                  </div>
                  <div className="space-y-1.5">
                    <p className="text-sm font-medium line-clamp-2 leading-tight min-h-[2.5rem]">
                      {product.name}
                    </p>
                    <p className="text-xs text-muted-foreground">{product.sku}</p>
                    <div className="flex items-center justify-between gap-2">
                      <p className="font-bold text-primary">
                        {formatKSh(displayPrice)}
                      </p>
                      {isWholesale && (
                        <span className="text-xs text-muted-foreground line-through">
                          {formatKSh(product.price)}
                        </span>
                      )}
                    </div>
                    <Badge
                      variant={stockInfo.color as "destructive" | "secondary"}
                      className={`text-xs ${
                        stockInfo.status === "low" ? "bg-warning/20 text-warning-foreground" : ""
                      }`}
                    >
                      {stockInfo.status === "low" && (
                        <AlertTriangle className="h-3 w-3 mr-1" />
                      )}
                      {stockInfo.label}
                    </Badge>
                  </div>
                </div>
              </Card>
            )
          })}
        </div>

        {products.length === 0 && (
          <div className="flex flex-col items-center justify-center py-16 text-center">
            <div className="h-16 w-16 rounded-full bg-muted flex items-center justify-center mb-4">
