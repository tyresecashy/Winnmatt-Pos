onCompletePayment={async (receiptNumber, paymentMethod, mpesaOptions) => {
  if (!profile?.id || !profile?.branch_id || cart.length === 0) {
    toast({...})
    return
  }

  setIsProcessingSale(true)
  
  try {
    // Transform cart items
