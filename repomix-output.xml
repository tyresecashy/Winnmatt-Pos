/**
 * CSV Import API Endpoint
 * POST /api/import/csv
 * Accepts CSV file upload and starts import pipeline
 */

import { NextRequest, NextResponse } from 'next/server'
import { createClient } from '@/lib/supabase-server'
import { parseCSVFile, importCSVBatch } from '@/lib/csv-importer'
import { processBatch } from '@/lib/staging-actions'

export async function POST(request: NextRequest) {
  try {
    const supabase = await createClient()

    // Check user authorization - admin only
    const {
      data: { user },
      error: authError,
    } = await supabase.auth.getUser()

    if (authError || !user) {
      return NextResponse.json(
        { error: 'Unauthorized' },
        { status: 401 }
      )
    }

    // Verify user is admin
    const { data: profile } = await supabase
      .from('users')
      .select('role')
      .eq('id', user.id)
      .single()

    if (!profile || profile.role !== 'admin') {
      return NextResponse.json(
        { error: 'Only admins can import products' },
        { status: 403 }
      )
    }

    // Parse form data
    const formData = await request.formData()
    const file = formData.get('file') as File
    const sourceName = (formData.get('source_name') as string) || 'csv_import'

    if (!file) {
      return NextResponse.json(
        { error: 'No file provided' },
        { status: 400 }
      )
    }

    // Validate file type
    if (!file.name.endsWith('.csv')) {
      return NextResponse.json(
        { error: 'Only CSV files are supported' },
        { status: 400 }
      )
    }

    // Validate file size (max 10MB)
    if (file.size > 10 * 1024 * 1024) {
      return NextResponse.json(
        { error: 'File too large (max 10MB)' },
        { status: 400 }
      )
    }

    console.log(`Importing CSV: ${file.name} (${file.size} bytes)`)

    // Step 1: Parse CSV
    const { products, errors: parseErrors } = await parseCSVFile(file)

    console.log(
      `CSV parsed: ${products.length} valid, ${parseErrors.length} errors`
    )

    if (products.length === 0) {
      return NextResponse.json(
        {
          error: 'No valid products in CSV',
          parseErrors,
        },
        { status: 400 }
      )
    }

    // Step 2: Import to database
    const importResult = await importCSVBatch(sourceName, products)

    console.log(`Imported batch ${importResult.batchId}`)

    // Step 3: Start processing pipeline async
    // This will normalize, dedupe, and analyze in the background
    processBatch(importResult.batchId).catch((error) => {
      console.error('Background processing failed:', error)
    })

    return NextResponse.json(
      {
        success: true,
        batchId: importResult.batchId,
        totalRecords: importResult.totalRecords,
        validRecords: importResult.validRecords,
        invalidRecords: importResult.invalidRecords,
        parseErrors:
          parseErrors.length > 0
            ? parseErrors.slice(0, 10) // Return first 10 errors
            : undefined,
        message: `Imported ${importResult.validRecords} products. Processing started...`,
      },
      { status: 200 }
    )
  } catch (error: any) {
    console.error('Import failed:', error)
    return NextResponse.json(
      {
        error: error.message || 'Import failed',
      },
      { status: 500 }
    )
  }
}

export async function OPTIONS(request: NextRequest) {
  return NextResponse.json({}, { status: 200 })
}
