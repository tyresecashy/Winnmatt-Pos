    totalSales: 0,
    transactionCount: 0,
    averageBasket: 0,
    activeCustomers: 0,
  })
  const [loading, setLoading] = useState(true)

  useEffect(() => {
    async function loadStats() {
      if (!profile?.branch_id) return

      setLoading(true)
      try {
        const data = await getTodayDashboardStats(profile.branch_id)
        setStats(data)
      } catch (error) {
        console.error('Error loading dashboard stats:', error)
      } finally {
        setLoading(false)
      }
    }

    loadStats()
  }, [profile?.branch_id])

  const dashboardStats = [
    {
      title: "Today's Sales",
      value: formatKSh(stats.totalSales),
      change: '+0',
      changeType: 'positive' as const,
      icon: TrendingUp,
      description: 'total revenue',
    },
    {
      title: 'Transactions',
      value: stats.transactionCount.toString(),
      change: stats.transactionCount > 0 ? `+${stats.transactionCount}` : '0',
      changeType: 'positive' as const,
      icon: ShoppingCart,
      description: 'completed sales',
    },
    {
      title: 'Avg. Basket Size',
      value: formatKSh(stats.averageBasket),
      change: stats.transactionCount > 0 ? '+0' : '0',
      changeType: 'positive' as const,
      icon: Package,
      description: 'per transaction',
    },
    {
      title: 'Active Customers',
      value: stats.activeCustomers.toString(),
      change: stats.activeCustomers > 0 ? `+${stats.activeCustomers}` : '0',
      changeType: 'positive' as const,
      icon: Users,
      description: 'today',
    },
  ]

  if (loading) {
    return (
      <div className="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {dashboardStats.map((stat) => (
          <Card key={stat.title} className="overflow-hidden">
            <CardContent className="p-6">
              <div className="space-y-2 animate-pulse">
                <div className="h-4 bg-muted rounded w-1/2"></div>
                <div className="h-8 bg-muted rounded w-3/4"></div>
              </div>
            </CardContent>
          </Card>
        ))}
      </div>
    )
  }

  return (
    <div className="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {dashboardStats.map((stat) => (
        <Card key={stat.title} className="overflow-hidden">
          <CardContent className="p-6">
            <div className="flex items-start justify-between">
              <div className="space-y-2">
                <p className="text-sm font-medium text-muted-foreground">
                  {stat.title}
