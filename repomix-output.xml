<file path="app/api/mpesa/stk-push/route.ts">
/**
 * M-Pesa STK Push Initiation Endpoint
 * POST /api/mpesa/stk-push
 * 
 * Initiates STK Push prompt on customer's phone
 */

import { NextRequest, NextResponse } from 'next/server'
import MpesaService from '@/lib/mpesa-service'
import {
  createMpesaTransaction,
  failMpesaSale,
} from '@/lib/mpesa-actions'
import { supabaseAdmin } from '@/lib/supabase-server'

interface STKPushRequest {
  saleId: string
  phoneNumber: string
  amount: number
  accountReference: string
  cashierId: string
  branchId: string
}

export async function POST(req: NextRequest) {
  try {
    // Validate environment variables
    if (
      !process.env.MPESA_CONSUMER_KEY ||
      !process.env.MPESA_CONSUMER_SECRET ||
      !process.env.MPESA_PAYBILL ||
      !process.env.MPESA_PASSKEY ||
      !process.env.MPESA_CALLBACK_URL
    ) {
      console.error('M-Pesa: Missing environment variables')
      return NextResponse.json(
        { error: 'M-Pesa configuration incomplete' },
        { status: 500 }
      )
    }

    const body: STKPushRequest = await req.json()

    // Validate request
    if (!body.saleId || !body.phoneNumber || !body.amount || !body.branchId) {
      return NextResponse.json(
        { error: 'Missing required fields: saleId, phoneNumber, amount, branchId' },
        { status: 400 }
      )
    }

    if (body.amount <= 0) {
      return NextResponse.json(
        { error: 'Amount must be greater than 0' },
        { status: 400 }
      )
    }

    // Verify sale exists and is in pending state
    const { data: sale, error: saleError } = await supabaseAdmin
      .from('sales')
      .select('id, payment_status, total_amount, branch_id')
      .eq('id', body.saleId)
      .single()

    if (saleError || !sale) {
      console.error('M-Pesa: Sale not found', body.saleId)
      return NextResponse.json(
        { error: 'Sale not found' },
        { status: 404 }
      )
    }

    if (sale.payment_status !== 'pending') {
      console.error('M-Pesa: Sale not in pending state', body.saleId, sale.payment_status)
      return NextResponse.json(
        { error: 'Sale is not awaiting M-Pesa payment' },
        { status: 400 }
      )
    }

    if (Math.abs(sale.total_amount - body.amount) > 1) {
      console.error('M-Pesa: Amount mismatch', body.amount, sale.total_amount)
      return NextResponse.json(
        { error: 'Amount does not match sale total' },
        { status: 400 }
      )
    }

    // Initialize M-Pesa service
    const mpesaService = new MpesaService({
      consumerKey: process.env.MPESA_CONSUMER_KEY,
      consumerSecret: process.env.MPESA_CONSUMER_SECRET,
      paybill: process.env.MPESA_PAYBILL,
      accountReference: process.env.MPESA_ACCOUNT_REFERENCE || body.accountReference,
      callbackUrl: process.env.MPESA_CALLBACK_URL,
      environment: (process.env.MPESA_ENVIRONMENT as 'sandbox' | 'production') || 'sandbox',
    })

    // Initiate STK Push
    console.log('M-Pesa: Initiating STK Push', {
      phone: body.phoneNumber,
      amount: body.amount,
      saleId: body.saleId,
    })

    const stkResponse = await mpesaService.initiateStkPush(
      body.phoneNumber,
      body.amount,
      body.accountReference,
      `POS Sale - Ref: ${body.accountReference}`,
      process.env.MPESA_PASSKEY
    )

    // Check response
    if (stkResponse.ResponseCode !== '0') {
      console.error('M-Pesa: STK Push failed', {
        ResponseCode: stkResponse.ResponseCode,
        ResponseDescription: stkResponse.ResponseDescription,
      })

      // Mark sale as failed
      await failMpesaSale(
        body.saleId,
        stkResponse.ResponseDescription
      )

      return NextResponse.json(
        {
          error: stkResponse.ResponseDescription,
          message: 'Failed to send STK Push prompt',
        },
        { status: 400 }
      )
    }

    // Create M-Pesa transaction record
    const transactionResult = await createMpesaTransaction(
      body.saleId,
      stkResponse.MerchantRequestID,
      stkResponse.CheckoutRequestID,
      body.phoneNumber,
      body.amount
    )

    if (!transactionResult.success) {
      console.error('M-Pesa: Failed to create transaction record')
      return NextResponse.json(
        { error: 'Failed to record M-Pesa transaction' },
        { status: 500 }
      )
    }

    console.log('M-Pesa: STK Push sent successfully', {
      checkoutRequestId: stkResponse.CheckoutRequestID,
      merchantRequestId: stkResponse.MerchantRequestID,
    })

    return NextResponse.json(
      {
        success: true,
        message: stkResponse.CustomerMessage,
        checkoutRequestId: stkResponse.CheckoutRequestID,
        merchantRequestId: stkResponse.MerchantRequestID,
      },
      { status: 200 }
    )
  } catch (error) {
    console.error('M-Pesa: STK Push endpoint error', error)
    return NextResponse.json(
      {
        error: 'Internal server error',
