    \"BusinessShortCode\": \"${PAYBILL}\",
    \"Password\": \"${PASSWORD}\",
    \"Timestamp\": \"${TIMESTAMP}\",
    \"CheckoutRequestID\": \"${CHECKOUT_REQUEST_ID}\"
