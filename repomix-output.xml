  const itemDiscountsTotal = safeItems.reduce(
    (sum, item) => sum + ((item?.unit_price || 0) * (item?.quantity || 0) * ((item?.discount_percent || 0) / 100)),
    0
  )

  // ========== END NORMALIZATION SECTION ==========

  const handlePrint = () => {
