/**
 * Update user profile (admin only)
 * Can update: full_name, role, branch_id
 * Cannot update: email (tied to Supabase Auth)
 */
export async function updateUser(
  userId: string,
  userRole: string,
  updates: {
    full_name?: string
    role?: 'admin' | 'manager' | 'cashier'
    branch_id?: string
  }
): Promise<UserProfile> {
  if (userRole !== 'admin') {
    throw new Error('Unauthorized: Only admins can update users')
  }

  if (!userId) {
    throw new Error('User ID required')
  }

  // Validate updates
  if (updates.role && !['admin', 'manager', 'cashier'].includes(updates.role)) {
    throw new Error('Invalid role')
  }

  const updateData: any = {}
  if (updates.full_name !== undefined) updateData.full_name = updates.full_name
  if (updates.role !== undefined) updateData.role = updates.role
  if (updates.branch_id !== undefined) updateData.branch_id = updates.branch_id
  updateData.updated_at = new Date().toISOString()

  const { data, error } = await supabaseAdmin
    .from('users')
    .update(updateData)
    .eq('id', userId)
    .select(
      `
      id,
      email,
      full_name,
      role,
      status,
      branch_id,
      created_at,
      updated_at,
      branch:branches(id, name, code)
    `
    )
    .single()

  if (error) {
    console.error('[USER-MANAGEMENT] Update user error:', error)
    throw new Error(`Failed to update user: ${error.message}`)
  }

  const branch = data.branch as any
  return {
    id: data.id,
    email: data.email,
    full_name: data.full_name,
    role: data.role,
    status: data.status,
    branch_id: data.branch_id,
    created_at: data.created_at,
    updated_at: data.updated_at,
    branch: branch ? {
      id: branch.id,
      name: branch.name,
      code: branch.code,
    } : undefined,
  } as UserProfile
}

/**
 * Delete user (soft delete - keeps auth, marks as deleted) (admin only)
 */
export async function deleteUser(
  userId: string,
  userRole: string
): Promise<{ success: boolean; message: string }> {
  if (userRole !== 'admin') {
    throw new Error('Unauthorized: Only admins can delete users')
  }

  if (!userId) {
    throw new Error('User ID required')
  }

  // Prevent deleting the last admin
  const { data: admins, error: adminCountError } = await supabaseAdmin
    .from('users')
    .select('id', { count: 'exact' })
    .eq('role', 'admin')

  if (!adminCountError && admins?.length <= 1) {
    const { data: targetUser } = await supabaseAdmin
      .from('users')
      .select('role')
      .eq('id', userId)
      .single()

    if (targetUser?.role === 'admin') {
      throw new Error('Cannot delete the last admin user')
    }
  }

  // Soft delete: remove profile, auth account remains untouched
  // This allows the user to still have their auth identity but no app access
  const { error } = await supabaseAdmin
    .from('users')
    .delete()
    .eq('id', userId)

  if (error) {
    console.error('[USER-MANAGEMENT] Delete user error:', error)
    throw new Error(`Failed to delete user: ${error.message}`)
  }

  return {
    success: true,
    message: 'User removed from system',
  }
}

/**
 * Reset user password (admin only)
 * Generates a new temporary password
 * User must change on first login
 */
export async function resetUserPassword(
  userId: string,
  userRole: string
): Promise<{
  tempPassword: string
  email: string
}> {
  if (userRole !== 'admin') {
    throw new Error('Unauthorized: Only admins can reset passwords')
  }

  if (!userId) {
    throw new Error('User ID required')
  }

  // Get user email
  const { data: user, error: userError } = await supabaseAdmin
    .from('users')
    .select('email')
    .eq('id', userId)
    .single()

  if (userError) {
    throw new Error(`User not found: ${userError.message}`)
  }

  // Generate new password
  const newPassword = Math.random().toString(36).slice(2, 10) + Math.random().toString(36).slice(2, 6).toUpperCase()

  // Update auth user password
  const { error: updateError } = await supabaseAdmin.auth.admin.updateUserById(userId, {
    password: newPassword,
  })

  if (updateError) {
    console.error('[USER-MANAGEMENT] Password reset error:', updateError)
    throw new Error(`Failed to reset password: ${updateError.message}`)
  }

  return {
    tempPassword: newPassword,
    email: user.email,
  }
}

export async function deactivateUser(userId: string, userRole: string) {
  if (userRole !== 'admin') {
    throw new Error('Unauthorized: Only admins can deactivate users')
  }

  const { data, error } = await supabaseAdmin
    .from('users')
    .update({ status: 'inactive', updated_at: new Date() })
    .eq('id', userId)
    .select()
    .single()

  if (error) {
    console.error('[USER-MANAGEMENT] Deactivate error:', error)
    throw new Error(`Failed to deactivate user: ${error.message}`)
  }

  return {
    success: true,
    user: data,
  }
}

export async function reactivateUser(userId: string, userRole: string) {
  if (userRole !== 'admin') {
    throw new Error('Unauthorized: Only admins can reactivate users')
  }

  const { data, error } = await supabaseAdmin
    .from('users')
    .update({ status: 'active', updated_at: new Date() })
    .eq('id', userId)
    .select()
    .single()

  if (error) {
    console.error('[USER-MANAGEMENT] Reactivate error:', error)
    throw new Error(`Failed to reactivate user: ${error.message}`)
  }

  return {
    success: true,
    user: data,
  }
}
