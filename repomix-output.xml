# WinnMatt POS - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ============================================================================
# Supabase (Database & Auth)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# M-Pesa (Safaricom Daraja)
# ============================================================================

# Get these from https://developer.safaricom.co.ke/
# 1. Go to "My Apps" and create an app
# 2. Navigate to "Credentials" section
# 3. Copy Consumer Key and Consumer Secret

# Consumer credentials (from Daraja)
MPESA_CONSUMER_KEY=your-consumer-key-here
MPESA_CONSUMER_SECRET=your-consumer-secret-here

# PayBill configuration
# Your Safaricom PayBill number (e.g., 522533)
MPESA_PAYBILL=522533

# Account reference (for grouping transactions)
# This is shown on customer's M-Pesa statement
# Use a meaningful identifier like "WinnMatt POS" or "Branch Name"
MPESA_ACCOUNT_REFERENCE=7617748

# Daraja Passkey
# This is generated when you register your app
# Get it from the Daraja dashboard
MPESA_PASSKEY=your-passkey-here

# Callback URL
# This is where Safaricom sends payment confirmations
# Must be publicly accessible (https)
# Example: https://api.winnmatt.com/api/mpesa/callback
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback

# Environment (sandbox or production)
# Use "sandbox" during development
# Use "production" for live payments
MPESA_ENVIRONMENT=sandbox

# ============================================================================
# Optional: Notifications (for real-time updates)
# ============================================================================

# Email for payment failure alerts (optional)
MPESA_FAILURE_EMAIL=admin@winnmatt.com

# ============================================================================
# Notes for each payment gateway
# ============================================================================

# DARAJA SANDBOX SETUP:
# 1. Go to https://developer.safaricom.co.ke/
# 2. Log in or sign up
# 3. Go to "My Apps" -> "Add New App"
# 4. Select "M-Pesa"
# 5. Fill in app details (name, callback URL)
# 6. Copy Consumer Key and Consumer Secret
# 7. Generate or copy Passkey
# 8. Use test phone numbers: 254708374149, 254717123456, etc.

# DARAJA PRODUCTION SETUP:
# 1. Apply for production access in Daraja
# 2. Get approved by Safaricom
# 3. Change MPESA_ENVIRONMENT to "production"
# 4. Update MPESA_CALLBACK_URL to production domain
# 5. Update Consumer Key/Secret to production credentials

# CALLBACK URL:
# - Must be publicly accessible (no localhost)
# - Must accept POST requests with JSON payload
# - Endpoint: /api/mpesa/callback
# - Must respond with HTTP 200 within 30 seconds
# - Safaricom will retry if no 200 response
</file>

