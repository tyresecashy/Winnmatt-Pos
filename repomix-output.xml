/**
 * Product Import Management Page
 * Admin page for managing CSV imports, staging review, and publishing
 */

'use client'

import { useEffect, useState } from 'react'
import { useRouter, useSearchParams } from 'next/navigation'
import { useSession } from 'next-auth/react'
import { useToast } from '@/hooks/use-toast'
import {
  Card,
  CardContent,
  CardDescription,
  CardHeader,
  CardTitle,
} from '@/components/ui/card'
import { Button } from '@/components/ui/button'
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@/components/ui/tabs'
import { Badge } from '@/components/ui/badge'
import {
  Select,
  SelectContent,
  SelectItem,
  SelectTrigger,
  SelectValue,
} from '@/components/ui/select'
import { Loader2, RefreshCw, CheckCircle, AlertTriangle } from 'lucide-react'
import { CSVUploadDialog } from '@/components/import/csv-upload-dialog'
import { StagingReviewTable } from '@/components/import/staging-review-table'
import { PublishDialog } from '@/components/import/publish-dialog'
import {
  getBatchSummary,
  getBatchStagingWithRelated,
} from '@/lib/staging-actions'
import ProtectedRoute from '@/components/protected-route'

export default function ImportPage() {
  const router = useRouter()
  const searchParams = useSearchParams()
  const { data: session } = useSession()
  const { toast } = useToast()

  const batchId = searchParams.get('batch')
  const [batches, setBatches] = useState<any[]>([])
  const [currentBatch, setCurrentBatch] = useState<any>(null)
  const [stagingProducts, setStagingProducts] = useState<any[]>([])
  const [loading, setLoading] = useState(false)
  const [refreshing, setRefreshing] = useState(false)
  const [activeTab, setActiveTab] = useState<'import' | 'review'>('import')
  const [publishDialogOpen, setPublishDialogOpen] = useState(false)

  // Fetch batch summary when batchId changes
  useEffect(() => {
    if (batchId) {
      loadBatchData()
    }
  }, [batchId])

  const loadBatchData = async () => {
    if (!batchId) return

    setLoading(true)
    try {
      const [summary, products] = await Promise.all([
        getBatchSummary(batchId),
        getBatchStagingWithRelated(batchId),
      ])

      setCurrentBatch(summary)
      setStagingProducts(products)

      // Auto-switch to review tab if products exist
      if (products.length > 0) {
        setActiveTab('review')
      }
    } catch (error: any) {
      toast({
        title: 'Load failed',
        description: error.message,
        variant: 'destructive',
      })
    } finally {
      setLoading(false)
    }
  }

  const handleImportComplete = (newBatchId: string) => {
    // Redirect to batch review
    router.push(`?batch=${newBatchId}`)
  }

  const handleRefresh = async () => {
    setRefreshing(true)
    await loadBatchData()
    setRefreshing(false)
  }

  const getApprovedCount = () => {
    return stagingProducts.filter(
      (p) => p.review_status === 'approved'
    ).length
  }

  const getPendingCount = () => {
    return stagingProducts.filter(
      (p) => p.review_status === 'pending'
    ).length
  }

  const getCriticalAnomalyCount = () => {
    return stagingProducts.filter((p) =>
      p.anomalies.some((a) => a.severity === 'critical')
    ).length
  }

  return (
    <ProtectedRoute requiredRole="admin">
      <div className="space-y-6">
        {/* Header */}
        <div>
          <h1 className="text-3xl font-bold">Product Ingestion</h1>
          <p className="text-gray-600">
            Import products via CSV, review for quality, and publish to live catalog
          </p>
        </div>

        {currentBatch ? (
          <>
            {/* Batch Summary */}
            <Card>
              <CardHeader>
                <div className="flex items-center justify-between">
                  <div>
                    <CardTitle className="flex items-center gap-2">
                      {currentBatch.batch.source_name}
                      <Badge variant="secondary">
                        {currentBatch.batch.total_records} products
                      </Badge>
                    </CardTitle>
                    <CardDescription>
                      Batch ID: {batchId} • Status: {currentBatch.batch.status}
                    </CardDescription>
                  </div>
                  <Button
                    variant="outline"
                    size="sm"
                    onClick={handleRefresh}
                    disabled={refreshing}
                  >
                    <RefreshCw
                      className={`w-4 h-4 ${refreshing ? 'animate-spin' : ''}`}
                    />
                  </Button>
                </div>
              </CardHeader>

              <CardContent>
                <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                  <div className="space-y-1">
                    <p className="text-sm text-gray-600">Pending Review</p>
                    <p className="text-2xl font-bold text-yellow-600">
                      {getPendingCount()}
                    </p>
                  </div>
                  <div className="space-y-1">
                    <p className="text-sm text-gray-600">Approved</p>
                    <p className="text-2xl font-bold text-green-600">
                      {getApprovedCount()}
                    </p>
                  </div>
                  <div className="space-y-1">
                    <p className="text-sm text-gray-600">Critical Issues</p>
                    <p className="text-2xl font-bold text-red-600">
                      {getCriticalAnomalyCount()}
                    </p>
                  </div>
                  <div className="space-y-1">
                    <p className="text-sm text-gray-600">Avg Confidence</p>
                    <p className="text-2xl font-bold text-blue-600">
                      {stagingProducts.length > 0
                        ? Math.round(
                            stagingProducts.reduce((sum, p) => sum + p.confidence_score, 0) /
                              stagingProducts.length
                          )
                        : 0}
                      %
                    </p>
                  </div>
                </div>

                {/* Status Badges */}
                <div className="mt-6 flex flex-wrap gap-2">
                  {getApprovedCount() > 0 && (
                    <Button
                      onClick={() => setPublishDialogOpen(true)}
                      className="bg-green-600 hover:bg-green-700"
                    >
                      <CheckCircle className="w-4 h-4 mr-2" />
                      Publish {getApprovedCount()} Products
                    </Button>
                  )}

                  {getCriticalAnomalyCount() > 0 && (
                    <div className="flex items-center gap-2 text-red-600 bg-red-50 px-3 py-2 rounded">
                      <AlertTriangle className="w-4 h-4" />
                      <span className="text-sm">
                        {getCriticalAnomalyCount()} products with critical issues
                      </span>
                    </div>
                  )}
                </div>
              </CardContent>
            </Card>

            {/* Tabs */}
            <Tabs value={activeTab} onValueChange={(v) => setActiveTab(v as any)}>
              <TabsList className="grid w-full grid-cols-2">
                <TabsTrigger value="import">Import Files</TabsTrigger>
                <TabsTrigger value="review">
                  Staging Review ({stagingProducts.length})
                </TabsTrigger>
              </TabsList>

              <TabsContent value="import" className="space-y-4">
                <Card>
                  <CardHeader>
                    <CardTitle>Import from CSV</CardTitle>
                    <CardDescription>
                      Upload a CSV file with product data. Supported columns: source_name,
                      source_product_id, scraped_name (required) + optional brand, unit,
                      category, listed_price, barcode, image_url, etc.
                    </CardDescription>
                  </CardHeader>
                  <CardContent className="space-y-4">
                    <CSVUploadDialog onImportComplete={handleImportComplete} />

                    <div className="bg-blue-50 border border-blue-200 rounded p-4 text-sm text-blue-900">
                      <p className="font-semibold mb-2">CSV Format Example:</p>
                      <div className="font-mono text-xs bg-white p-2 rounded overflow-auto">
                        source_name,source_product_id,scraped_name,brand,unit,listed_price
                        <br />
                        jumia,JUMIA123,Coca Cola 500ml,Coca Cola,ml,150
                        <br />
                        jumia,JUMIA456,Sprite 2L,Sprite,l,300
                      </div>
                    </div>
                  </CardContent>
                </Card>
              </TabsContent>

              <TabsContent value="review" className="space-y-4">
                {loading ? (
                  <div className="flex items-center justify-center py-12">
                    <Loader2 className="w-6 h-6 animate-spin text-gray-400" />
                  </div>
                ) : stagingProducts.length > 0 ? (
                  <>
                    <Card>
                      <CardHeader>
                        <CardTitle>Review & Approve Products</CardTitle>
                        <CardDescription>
                          Check for issues, adjust prices, and approve for publishing.
                          Critical anomalies must be resolved before approval.
                        </CardDescription>
                      </CardHeader>
                      <CardContent>
                        <StagingReviewTable
                          products={stagingProducts}
                          onApprove={handleRefresh}
                          onReject={handleRefresh}
                        />
                      </CardContent>
                    </Card>
                  </>
                ) : (
                  <Card className="text-center py-12">
                    <CardDescription>
                      No staging products yet. Upload and process a CSV file to get started.
                    </CardDescription>
                  </Card>
                )}
              </TabsContent>
            </Tabs>

            {/* Publish Dialog */}
            <PublishDialog
              batchId={batchId!}
              approvedCount={getApprovedCount()}
              onPublishComplete={handleRefresh}
              open={publishDialogOpen}
              onOpenChange={setPublishDialogOpen}
            />
          </>
        ) : (
          <>
            {/* Empty State */}
            <Card className="text-center py-12">
              <CardHeader>
                <CardTitle>No Batch Selected</CardTitle>
                <CardDescription className="text-base">
                  Upload a CSV file to get started with product ingestion
                </CardDescription>
              </CardHeader>
              <CardContent>
                <CSVUploadDialog onImportComplete={handleImportComplete} />
              </CardContent>
            </Card>
          </>
        )}
      </div>
    </ProtectedRoute>
  )
}
</file>

