/**
 * CSV Importer Service
 * Handles CSV parsing, validation, and insertion into product_imports table
 * DO NOT publish directly - imports go to staging for review
 */

import { createClient } from '@/lib/supabase-server'
import { v4 as uuidv4 } from 'uuid'
import Papa from 'papaparse'

export interface CSVProduct {
  source_name: string
  source_product_id: string
  source_url?: string
  scraped_name: string
  brand?: string
  pack_size?: string
  unit?: string
  category?: string
  listed_price?: number
  currency?: string
  barcode?: string
  image_url?: string
  // Allow additional fields from CSV
  [key: string]: any
}

export interface ImportResult {
  batchId: string
  totalRecords: number
  validRecords: number
  invalidRecords: number
  errors: { row: number; field: string; message: string }[]
}

/**
 * Parse CSV file and extract products
 */
export async function parseCSVFile(file: File): Promise<{
  products: CSVProduct[]
  errors: { row: number; message: string }[]
}> {
  return new Promise((resolve) => {
    const products: CSVProduct[] = []
    const errors: { row: number; message: string }[] = []

    Papa.parse(file, {
      header: true,
      skipEmptyLines: true,
      error: (error) => {
        errors.push({
          row: 0,
          message: `CSV parse error: ${error.message}`,
        })
      },
      complete: (results) => {
        // Validate each row
        results.data.forEach((row: any, index: number) => {
          const rowNum = index + 2 // +1 for header, +1 for 1-based indexing

          // Check required fields
          if (!row.source_name?.trim()) {
            errors.push({
              row: rowNum,
              message: 'Missing required field: source_name',
            })
            return
          }

          if (!row.source_product_id?.toString().trim()) {
            errors.push({
              row: rowNum,
              message: 'Missing required field: source_product_id',
            })
            return
          }

          if (!row.scraped_name?.trim()) {
            errors.push({
              row: rowNum,
              message: 'Missing required field: scraped_name',
            })
            return
          }

          // Convert listed_price to number
          let listedPrice: number | undefined
          if (row.listed_price) {
            const parsed = parseFloat(row.listed_price)
            if (!isNaN(parsed)) {
              listedPrice = Math.round(parsed) // Store as integer (KES)
            }
          }

          // Build product record
          const product: CSVProduct = {
            source_name: row.source_name.trim(),
            source_product_id: row.source_product_id.toString().trim(),
            source_url: row.source_url?.trim() || undefined,
            scraped_name: row.scraped_name.trim(),
            brand: row.brand?.trim() || undefined,
            pack_size: row.pack_size?.trim() || undefined,
            unit: row.unit?.trim() || undefined,
            category: row.category?.trim() || undefined,
            listed_price: listedPrice,
            currency: row.currency?.trim() || 'KES',
            barcode: row.barcode?.trim() || undefined,
            image_url: row.image_url?.trim() || undefined,
          }

          products.push(product)
        })

        resolve({ products, errors })
      },
    })
  })
}

/**
 * Create import batch and insert raw CSV data into product_imports
 * Does NOT publish to live products - only to staging
 */
export async function importCSVBatch(
  sourceName: string,
  products: CSVProduct[]
): Promise<ImportResult> {
  const supabase = await createClient()

  // 1. Create import batch record
  const batchId = uuidv4()
  const { error: batchError } = await supabase
    .from('product_import_batches')
    .insert({
      id: batchId,
      source_name: sourceName,
      total_records: products.length,
      status: 'normalizing', // Start with normalizing
      started_at: new Date().toISOString(),
    })

  if (batchError) {
    throw new Error(`Failed to create import batch: ${batchError.message}`)
  }

  // 2. Insert raw product data into product_imports
  const imports = products.map((product) => ({
    id: uuidv4(),
    batch_id: batchId,
    source_name: product.source_name,
    source_product_id: product.source_product_id,
    raw_data: product, // Store entire row as JSONB
    created_at: new Date().toISOString(),
  }))

  const { error: importsError, data: importedData } = await supabase
    .from('product_imports')
    .insert(imports)
    .select()

  if (importsError) {
    // Rollback batch if imports fail
    await supabase.from('product_import_batches').delete().eq('id', batchId)
    throw new Error(`Failed to import products: ${importsError.message}`)
  }

  return {
    batchId,
    totalRecords: products.length,
    validRecords: products.length,
    invalidRecords: 0,
    errors: [],
  }
}

/**
 * Get import batch details
 */
export async function getImportBatch(batchId: string) {
  const supabase = await createClient()

  const { data, error } = await supabase
    .from('product_import_batches')
    .select('*')
    .eq('id', batchId)
    .single()

  if (error) {
    throw new Error(`Failed to get batch: ${error.message}`)
  }

  return data
}

/**
 * Get raw imports for a batch (before normalization)
 */
export async function getRawImports(batchId: string) {
  const supabase = await createClient()

  const { data, error } = await supabase
    .from('product_imports')
    .select('*')
    .eq('batch_id', batchId)
    .order('created_at', { ascending: true })

  if (error) {
    throw new Error(`Failed to get raw imports: ${error.message}`)
  }

  return data || []
}

/**
 * Get summary stats for a batch
 */
export async function getImportBatchStats(batchId: string) {
  const supabase = await createClient()

  // Total imports
  const { count: totalImports } = await supabase
    .from('product_imports')
    .select('id', { count: 'exact', head: true })
    .eq('batch_id', batchId)

  // Staging products from this batch
  const { count: stagingProducts } = await supabase
    .from('products_staging')
    .select('id', { count: 'exact', head: true })
    .eq('batch_id', batchId)

  // Anomalies from this batch
  const { count: anomalies } = await supabase
    .from('price_anomalies')
    .select('id', { count: 'exact', head: true })
    .eq('batch_id', batchId)

  // Deduplications (potential matches)
  const { count: potentialDupes } = await supabase
    .from('product_deduplications')
    .select('id', { count: 'exact', head: true })
    .eq('batch_id', batchId)
    .eq('match_type', 'fuzzy')

  return {
    totalImports: totalImports || 0,
    stagingProducts: stagingProducts || 0,
    anomalies: anomalies || 0,
    potentialDuplicates: potentialDupes || 0,
  }
}
