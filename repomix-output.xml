<file path="components/receipt-preview.tsx">
'use client'

import { formatKSh } from '@/lib/currency'
import { Button } from '@/components/ui/button'
import { Printer, X } from 'lucide-react'

export interface SaleItem {
  id: string
  product_id: string
  quantity: number
  unit_price: number
  discount_percent: number
  line_total: number
  product: {
    id: string
    sku: string
    name: string
  }
}

export interface SaleDetailsData {
  id: string
  receipt_number: string
  created_at: string
  subtotal: number
  discount_amount: number
  tax_amount: number
  total_amount: number
  payment_method: string
  payment_status: string
  notes: string | null
  
  // Relations
  cashier: {
    id: string
    full_name: string
  }
  customer: {
    id: string
    name: string
    phone: string
    loyalty_points?: number
  } | null
  branch: {
    id: string
    name: string
    code: string
  }
  items: SaleItem[]
  
  // Settings
  businessSettings: {
    business_name: string
    phone: string
    email: string
    address: string
    tax_pin: string
    receipt_footer_text: string
    thank_you_message: string
  }
  branchSettings?: {
    receipt_header_text: string
    phone_number: string
    email: string
    address: string
  }
  
  // Loyalty info (optional)
  loyalty?: {
    points_earned: number
    points_redeemed?: number
    new_balance: number
  }
}

interface ReceiptPreviewProps {
  saleData: SaleDetailsData
  showPrintButton?: boolean
  showCloseButton?: boolean
  onPrint?: () => void
  onClose?: () => void
}

export function ReceiptPreview({
  saleData,
  showPrintButton = true,
  showCloseButton = true,
  onPrint,
  onClose,
}: ReceiptPreviewProps) {
  // ========== DEFENSIVE NORMALIZATION SECTION ==========
  // Create safe versions of all saleData properties to prevent crashes
  
  console.log('[DEBUG] ReceiptPreview - saleData received:', {
    saleId: saleData?.id,
    hasItems: !!saleData?.items,
    itemsLength: saleData?.items?.length,
    receiptNumber: saleData?.receipt_number,
    totalAmount: saleData?.total_amount,
    paymentMethod: saleData?.payment_method,
    cashierName: saleData?.cashier?.full_name,
    customerName: saleData?.customer?.name,
    branchName: saleData?.branch?.name,
    hasBusinessSettings: !!saleData?.businessSettings,
    saleDataKeys: Object.keys(saleData || {}),
  })
  
  // Safe business settings
  const safeBusiness = {
    name: saleData?.businessSettings?.business_name || 'Winnmatt',
    phone: saleData?.businessSettings?.phone || '',
    email: saleData?.businessSettings?.email || '',
    address: saleData?.businessSettings?.address || '',
    tax_pin: saleData?.businessSettings?.tax_pin || '',
    thank_you_message: saleData?.businessSettings?.thank_you_message || 'Thank you for your purchase!',
    receipt_footer_text: saleData?.businessSettings?.receipt_footer_text || '',
  }

  // Safe branch settings
  const safeBranch = {
    name: saleData?.branch?.name || 'Main Branch',
    code: saleData?.branch?.code || '',
    header_text: saleData?.branchSettings?.receipt_header_text || '',
  }

  // Safe cashier
  const safeCashier = {
    name: saleData?.cashier?.full_name || 'Unknown Cashier',
  }

  // Safe customer
  const safeCustomer = {
    name: saleData?.customer?.name || null,
    phone: saleData?.customer?.phone || null,
    loyalty_points: saleData?.customer?.loyalty_points || 0,
  }

  // Safe items array
  const safeItems: SaleItem[] = Array.isArray(saleData?.items) ? saleData.items : []

  // Safe receipt metadata
  const safeReceiptNumber = saleData?.receipt_number || 'UNKNOWN'
  
  // Safe date/time parsing
  let dateStr = 'N/A'
  let timeStr = 'N/A'
  try {
    if (saleData?.created_at) {
      const receiptDate = new Date(saleData.created_at)
      if (!isNaN(receiptDate.getTime())) {
        dateStr = receiptDate.toLocaleDateString('en-KE', {
          year: 'numeric',
          month: '2-digit',
          day: '2-digit',
        })
        timeStr = receiptDate.toLocaleTimeString('en-KE', {
          hour: '2-digit',
          minute: '2-digit',
          second: '2-digit',
        })
      }
    }
  } catch (error) {
    console.error('Failed to parse receipt date:', error)
  }

  // Safe payment method
  const paymentMethodMap: Record<string, string> = {
    'cash': 'CASH',
    'mpesa': 'M-PESA',
    'paybill': 'PAYBILL',
    'card': 'CARD',
    'bank_transfer': 'BANK TRANSFER',
  }
  const safePaymentMethod = saleData?.payment_method
    ? paymentMethodMap[saleData.payment_method] || (String(saleData.payment_method) || 'UNKNOWN').toUpperCase()
    : 'UNKNOWN'

  // Safe totals
  const safeTotals = {
    subtotal: typeof saleData?.subtotal === 'number' ? saleData.subtotal : 0,
    discount_amount: typeof saleData?.discount_amount === 'number' ? saleData.discount_amount : 0,
    tax_amount: typeof saleData?.tax_amount === 'number' ? saleData.tax_amount : 0,
    total_amount: typeof saleData?.total_amount === 'number' ? saleData.total_amount : 0,
  }

  // Safe payment status
  const safePaymentStatus = saleData?.payment_status || 'completed'

  // Safe loyalty data
  const safeLoyalty = saleData?.loyalty
    ? {
        points_earned: saleData.loyalty.points_earned || 0,
        points_redeemed: saleData.loyalty.points_redeemed || 0,
        new_balance: saleData.loyalty.new_balance || 0,
      }
    : null

  // Safe notes
  const safeNotes = typeof saleData?.notes === 'string' ? saleData.notes : null

