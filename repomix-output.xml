export async function getInventoryForBranch(branchId: string) {
  try {
    console.log('[INVENTORY] Fetching inventory for branch:', branchId)
    
    // APPROACH 1: Try with nested relations (Supabase primary method)
    console.log('[INVENTORY] Attempt 1: Fetching with nested product/category relations...')
    const { data, error } = await supabaseAdmin
      .from('inventory')
      .select(`
        id,
        quantity,
        branch_id,
        product_id,
        created_at,
        updated_at,
        product:products(
          id, 
          sku, 
          name, 
          selling_price, 
          purchase_price, 
          reorder_level, 
          category_id,
          category:categories(id, name, icon)
        )
      `)
      .eq('branch_id', branchId)
      .order('product(name)')

    if (error) {
      console.warn('[INVENTORY] Attempt 1 failed:', error.message)
      console.log('[INVENTORY] Attempt 2: Trying simplified select without nested relations...')
      
      // APPROACH 2: Fallback - fetch without category relation
      const { data: data2, error: error2 } = await supabaseAdmin
        .from('inventory')
        .select(`
          id,
          quantity,
          branch_id,
          product_id,
          created_at,
          updated_at,
          product:products(
            id, 
            sku, 
            name, 
            selling_price, 
            purchase_price, 
            reorder_level, 
            category_id
          )
        `)
        .eq('branch_id', branchId)

      if (error2) {
        console.error('[INVENTORY] Attempt 2 also failed:', error2.message)
        console.log('[INVENTORY] Attempt 3: Trying without any relations...')
        
        // APPROACH 3: Last resort - fetch raw inventory, then products separately
        const { data: inventoryRows, error: error3 } = await supabaseAdmin
          .from('inventory')
          .select('*')
          .eq('branch_id', branchId)
          .order('product_id')

        if (error3) {
          console.error('[INVENTORY] Attempt 3 failed:', error3.message)
          console.error('[INVENTORY] Error details:', { code: error3.code, message: error3.message, details: error3.details })
          return []
        }

        console.log('[INVENTORY] Attempt 3 succeeded! Fetched', inventoryRows?.length || 0, 'inventory rows')

        if (!inventoryRows || inventoryRows.length === 0) {
          console.warn('[INVENTORY] No inventory rows found for branch:', branchId)
          return []
        }

        // Fetch all products referenced by these inventory rows
        const productIds = inventoryRows.map(row => row.product_id)
        const { data: products, error: productError } = await supabaseAdmin
          .from('products')
          .select('id, sku, name, selling_price, purchase_price, reorder_level, category_id, category:categories(id, name, icon)')
          .in('id', productIds)

        if (productError) {
          console.error('[INVENTORY] Failed to fetch products:', productError.message)
          // Return inventory without product details as fallback
          return (inventoryRows as any[]).map(row => ({ ...row, product: null }))
        }

        console.log('[INVENTORY] Fetched', products?.length || 0, 'products')

        // Merge products back into inventory rows
        const productMap: any = Object.fromEntries(
          (products || []).map((p: any) => [p.id, p])
        )

        const result = inventoryRows.map((invRow: any) => ({
          ...invRow,
          product: productMap[invRow.product_id] || null,
        }))

        console.log('[INVENTORY] Merged result count:', result.length)
        if (result[0]) {
          console.log('[INVENTORY] First merged item:', JSON.stringify(result[0], null, 2))
        }
        return result
      }

      console.log('[INVENTORY] Attempt 2 succeeded! Fetched', data2?.length || 0, 'rows')
      return data2 || []
    }

    console.log('[INVENTORY] Attempt 1 succeeded! Fetched', data?.length || 0, 'rows')
    
    if (data && data.length > 0) {
      console.log('[INVENTORY] First item:', JSON.stringify(data[0], null, 2))
    }
    
    return data || []
  } catch (error) {
    console.error('[INVENTORY] Unexpected error:', error)
    return []
  }
}

