)

// 2. Send STK Push
const stkResponse = await fetch('/api/mpesa/stk-push', {
  method: 'POST',
  body: JSON.stringify({
    saleId: sale.id,
    phoneNumber: customerPhone,
    amount: total,
    accountReference: accountRef,
