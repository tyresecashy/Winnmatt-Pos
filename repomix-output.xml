  const [branchSaveStatus, setBranchSaveStatus] = useState<'idle' | 'success' | 'error'>('idle')
  const [branchSaveMessage, setBranchSaveMessage] = useState('')
  
  // Loyalty settings state
  const [loyaltySettings, setLoyaltySettings] = useState<LoyaltySettings | null>(null)
  const [loyaltyFormData, setLoyaltyFormData] = useState<Partial<LoyaltySettings>>({})
  const [savingLoyalty, setSavingLoyalty] = useState(false)
  const [loyaltySaveStatus, setLoyaltySaveStatus] = useState<'idle' | 'success' | 'error'>('idle')
  const [loyaltySaveMessage, setLoyaltySaveMessage] = useState('')
  
  // Load business and loyalty settings on mount
  useEffect(() => {
    const loadSettings = async () => {
      try {
        const [business, loyalty] = await Promise.all([
          getBusinessSettings(),
          getLoyaltySettings()
        ])
        if (business) {
          setBusinessSettings(business)
          setFormData(business)
        }
        if (loyalty) {
          setLoyaltySettings(loyalty)
          setLoyaltyFormData(loyalty)
        }
      } catch (err) {
        console.error('Failed to load settings:', err)
        setSaveStatus('error')
        setSaveMessage('Failed to load settings')
      } finally {
        setLoading(false)
      }
    }
    
    loadSettings()
  }, [])
  
  // Handle business field change
  const handleFormChange = (field: keyof BusinessSettings, value: string) => {
    setFormData(prev => ({
      ...prev,
      [field]: value || null
    }))
  }
  
  // Save business settings
  const handleSaveBusinessSettings = async () => {
    if (!profile || profile.role !== 'admin') {
      setSaveStatus('error')
      setSaveMessage('Only admins can edit receipt settings')
      return
    }
    
    try {
      setSaving(true)
      setSaveStatus('idle')
      
      const updated = await updateBusinessSettings(profile.role, formData)
      setBusinessSettings(updated)
      setSaveStatus('success')
      setSaveMessage('Receipt settings saved successfully')
      
      setTimeout(() => setSaveStatus('idle'), 3000)
    } catch (err) {
      setSaveStatus('error')
      setSaveMessage(err instanceof Error ? err.message : 'Failed to save settings')
    } finally {
      setSaving(false)
    }
  }
  
  // Handle branch selection
  const handleBranchSelect = (branchId: string) => {
    setSelectedBranch(branchId)
    setBranchFormData({})
    setBranchSaveStatus('idle')
  }
  
  // Handle branch field change
