  "MerchantRequestID": "17614-42849-2",
  "CheckoutRequestID": "ws_CO_XXXXXXXXXXXXX",
  "ResultCode": 0,
  "ResultDesc": "The service request has been processed successfully.",
  "Amount": "100",
