# =============================================================================
# WinnMatt POS — Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your actual values.
#
# Categories:
#   [REQUIRED]      — App crashes at startup if absent
#   [OPTIONAL]      — Feature degrades gracefully when absent
#   [BUILD-TIME]    — Only needed during build (not in Zod schema)

# █████████████████████████████████████████████████████████████████████████████
#  REQUIRED: Supabase (Database & Auth)
# █████████████████████████████████████████████████████████████████████████████
# All three must be present for database and auth to function.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyjanon...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyjsrv...your-service-role-key

# █████████████████████████████████████████████████████████████████████████████
#  REQUIRED: Tuma Payments — Primary M-Pesa Payment Provider
# █████████████████████████████████████████████████████████████████████████████
# The main POS uses Tuma for all M-Pesa STK Push payments.
# The POS cannot process payments without these.
# TUMA_API_URL defaults to https://api.tuma.co.ke if omitted.

TUMA_API_KEY=your-tuma-api-key
TUMA_BUSINESS_EMAIL=your-tuma-business-email@example.com
# TUMA_API_URL=https://api.tuma.co.ke
TUMA_CALLBACK_URL=https://your-domain.com/api/payments/tuma/callback

# █████████████████████████████████████████████████████████████████████████████
#  REQUIRED: Stripe — Card Payments
# █████████████████████████████████████████████████████████████████████████████
# Used for card payment processing in the POS and Stripe Checkout.

STRIPE_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# █████████████████████████████████████████████████████████████████████████████
#  OPTIONAL: M-Pesa Daraja — Legacy Mobile POS Only
# █████████████████████████████████████████████████████████████████████████████
# Legacy Safaricom Daraja integration — only used by the Mobile POS.
# The app starts without these; Mobile POS will show "M-Pesa unavailable".
# Production MPESA_PASSKEY must be obtained from the Safaricom Daraja portal
# (App Settings > Security Credentials).
#
# NOTE: The main POS uses Tuma Payments (above), NOT Daraja.

# MPESA_CONSUMER_KEY=your-consumer-key
# MPESA_CONSUMER_SECRET=your-consumer-secret
# MPESA_PAYBILL=522533
# MPESA_PASSKEY=your-production-passkey
# MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback
# MPESA_ENVIRONMENT=sandbox
# MPESA_ACCOUNT_REFERENCE=WINNMATT

# █████████████████████████████████████████████████████████████████████████████
#  OPTIONAL: Redis — Event Bus Backend
# █████████████████████████████████████████████████████████████████████████████
# Without Redis the event bus runs in-memory: events are delivered only to
# currently-connected SSE clients and are lost on server restart.
# Recommended for production. Accepts redis:// or rediss:// URLs.

# REDIS_URL=redis://user:password@host:6379

# █████████████████████████████████████████████████████████████████████████████
#  OPTIONAL: Email & SMS Notifications
# █████████████████████████████████████████████████████████████████████████████
# Email via Resend, SMS via Africa's Talking. When absent, notification calls
# log to notification_logs without sending.

# RESEND_API_KEY=re_xxxxxxxxxxxx
# EMAIL_FROM=WinnMatt POS <notifications@winnmatt.com>
# AFRICASTALKING_API_KEY=atsk_xxxxxxxxxxxx
# AFRICASTALKING_USERNAME=sandbox
# SMS_FROM=WINNMATT

# █████████████████████████████████████████████████████████████████████████████
#  OPTIONAL: Webhook Notifications
# █████████████████████████████████████████████████████████████████████████████
# Outgoing webhooks for external system integration.

# WEBHOOK_NOTIFICATION_URL=https://hooks.example.com/notify
# WEBHOOK_NOTIFICATION_SECRET=your-webhook-secret

# █████████████████████████████████████████████████████████████████████████████
#  OPTIONAL: FCM Push Notifications (Firebase Cloud Messaging)
# █████████████████████████████████████████████████████████████████████████████
# Server key for sending push notifications to mobile devices.

# FIREBASE_SERVER_KEY=AAAAxxxxxxxxxxx:APA91xxxxxxxxxxxx

# █████████████████████████████████████████████████████████████████████████████
#  OPTIONAL: AI Functional Assistant
# █████████████████████████████████████████████████████████████████████████████
# OpenRouter key for the AI Functional Assistant. Without it the AI chat UI
# shows a "not available" message. Uses free-tier models; no paid API needed.

# OPENROUTER_API_KEY=sk-or-v1-your-key-here

# █████████████████████████████████████████████████████████████████████████████
#  BUILD-TIME: Sentry Error Tracking
# █████████████████████████████████████████████████████████████████████████████
# Sentry is configured via next.config.mjs (withSentryConfig).
# These are read via process.env at build time — NOT in the app's Zod schema.
# If unset, the Sentry SDK runs in silent mode (no uploads, no errors).

# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_DSN=https://your-dsn@sentry.io/project-id
