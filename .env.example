# WinnMatt POS - Environment Variables Template
# Copy this file to .env.local and fill in your actual values

# ============================================================================
# REQUIRED: Supabase (Database & Auth)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# App Configuration
# ============================================================================
NEXT_PUBLIC_APP_NAME=WINNMATT POS
NEXT_PUBLIC_API_URL=https://your-domain.com

# ============================================================================
# M-Pesa (Safaricom Daraja) - OPTIONAL for production
# ============================================================================
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PAYBILL=522533
MPESA_ACCOUNT_REFERENCE=7617748
MPESA_PASSKEY=your-passkey
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback
MPESA_ENVIRONMENT=production  # sandbox or production

# ============================================================================
# OPTIONAL: OpenRouter AI (for AI features)
# ============================================================================
OPENROUTER_API_KEY=sk-or-v1-your-key

# ============================================================================
# OPTIONAL: Sentry (for error tracking)
# ============================================================================
SENTRY_ORG=your-org
SENTRY_PROJECT=your-project
SENTRY_DSN=https://your-dsn@sentry.io/project-id
